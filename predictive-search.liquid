<section class="pf-hero">
  <div class="page-width">
    <div class="pf-hero__bg"></div>

    <div class="pf-hero__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="pf-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="pf-hero__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="pf-hero__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="pf-hero__jumps">
      <a href="#pf-apparel" class="pf-hero__jump">
        <span class="pf-hero__jump-topbar"></span>
        <div class="pf-hero__jump-content">
          <span class="pf-hero__jump-num">01</span>
          <div class="pf-hero__jump-copy">
            <span class="pf-hero__jump-label">Apparel</span>
            <span class="pf-hero__jump-desc">Custom clothing, team gear, uniforms, and branded apparel</span>
          </div>
        </div>
        <span class="pf-hero__jump-arrow">↓</span>
      </a>

      <a href="#pf-design" class="pf-hero__jump">
        <span class="pf-hero__jump-topbar"></span>
        <div class="pf-hero__jump-content">
          <span class="pf-hero__jump-num">02</span>
          <div class="pf-hero__jump-copy">
            <span class="pf-hero__jump-label">Graphic Design</span>
            <span class="pf-hero__jump-desc">Logos, brand identity, apparel artwork, and print-ready design</span>
          </div>
        </div>
        <span class="pf-hero__jump-arrow">↓</span>
      </a>

      <a href="#pf-promo" class="pf-hero__jump">
        <span class="pf-hero__jump-topbar"></span>
        <div class="pf-hero__jump-content">
          <span class="pf-hero__jump-num">03</span>
          <div class="pf-hero__jump-copy">
            <span class="pf-hero__jump-label">Promo Products</span>
            <span class="pf-hero__jump-desc">Branded merchandise, giveaways, event kits, and promotional items</span>
          </div>
        </div>
        <span class="pf-hero__jump-arrow">↓</span>
      </a>

      <a href="#pf-large-format" class="pf-hero__jump">
        <span class="pf-hero__jump-topbar"></span>
        <div class="pf-hero__jump-content">
          <span class="pf-hero__jump-num">04</span>
          <div class="pf-hero__jump-copy">
            <span class="pf-hero__jump-label">Large Format Branding</span>
            <span class="pf-hero__jump-desc">Banners, backdrops, signage, wall graphics, decals, and event displays</span>
          </div>
        </div>
        <span class="pf-hero__jump-arrow">↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .pf-hero {
    position: relative;
    overflow: hidden;
    padding: 88px 0 72px;
    background:
      radial-gradient(circle at top right, rgba(196, 18, 48, 0.22), transparent 28%),
      linear-gradient(135deg, #0f0f10 0%, #171717 58%, #1f1f1f 100%);
    color: #ffffff;
  }

  .pf-hero .page-width {
    position: relative;
    z-index: 2;
  }

  .pf-hero__bg::before,
  .pf-hero__bg::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .pf-hero__bg::before {
    top: -120px;
    right: -120px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196, 18, 48, 0.22) 0%, rgba(196, 18, 48, 0) 72%);
    filter: blur(8px);
  }

  .pf-hero__bg::after {
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  .pf-hero__intro {
    max-width: 820px;
    margin: 0 auto 54px;
    text-align: center;
  }

  .pf-hero__eyebrow {
    margin: 0 0 12px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pf-hero__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3.8rem, 5.4vw, 6.6rem);
    line-height: 0.94;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .pf-hero__text {
    margin: 0;
    font-size: 1.7rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.76);
  }

  .pf-hero__jumps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .pf-hero__jump {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 152px;
    padding: 28px 24px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-bottom: 4px solid rgba(255,255,255,0.14);
    text-decoration: none;
    color: #ffffff;
    overflow: hidden;
    box-shadow: 0 5px 0 rgba(0,0,0,0.28);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .pf-hero__jump:hover {
    transform: translateY(-6px);
    background: rgba(196,18,48,0.12);
    border-color: rgba(196,18,48,0.9);
    border-bottom-color: #8f0d22;
    box-shadow: 0 12px 0 rgba(0,0,0,0.2), 0 18px 34px rgba(0,0,0,0.22);
  }

  .pf-hero__jump:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .pf-hero__jump-topbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: #c41230;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s ease;
  }

  .pf-hero__jump:hover .pf-hero__jump-topbar {
    transform: scaleX(1);
  }

  .pf-hero__jump-content {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .pf-hero__jump-num {
    flex-shrink: 0;
    font-family: var(--sole-heading-font);
    font-size: 3.2rem;
    line-height: 1;
    font-weight: 900;
    color: #c41230;
  }

  .pf-hero__jump-copy {
    min-width: 0;
  }

  .pf-hero__jump-label {
    display: block;
    margin-bottom: 6px;
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .pf-hero__jump-desc {
    display: block;
    font-size: 1.35rem;
    line-height: 1.45;
    color: rgba(255,255,255,0.58);
  }

  .pf-hero__jump-arrow {
    flex-shrink: 0;
    font-size: 2rem;
    line-height: 1;
    color: rgba(255,255,255,0.28);
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .pf-hero__jump:hover .pf-hero__jump-arrow {
    color: #c41230;
    transform: translateY(4px);
  }

  @media screen and (max-width: 1200px) {
    .pf-hero__jumps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .pf-hero {
      padding: 68px 0 56px;
    }

    .pf-hero__jumps {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .pf-hero__jump {
      min-height: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .pf-hero__heading {
      font-size: clamp(3.2rem, 11vw, 4.8rem);
    }

    .pf-hero__text {
      font-size: 1.5rem;
    }

    .pf-hero__jump {
      padding: 22px 18px;
    }

    .pf-hero__jump-content {
      gap: 14px;
    }

    .pf-hero__jump-num {
      font-size: 2.7rem;
    }

    .pf-hero__jump-label {
      font-size: 1.7rem;
    }

    .pf-hero__jump-desc {
      font-size: 1.25rem;
    }
  }
</style>

{% schema %}
{
  "name": "Portfolio Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Work" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built By The Sole Provider" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "From custom apparel to branded merch to logo design — here’s a look at what we’ve built for our clients." }
  ],
  "presets": [
    { "name": "Portfolio Hero" }
  ]
}
{% endschema %}