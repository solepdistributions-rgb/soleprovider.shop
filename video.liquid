<section class="value-pillars">
  <div class="page-width">
    <div class="value-pillars__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="value-pillars__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="value-pillars__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="value-pillars__grid">
      {% for block in section.blocks %}
        <div class="value-pillars__card" {{ block.shopify_attributes }}>
          <p class="value-pillars__number">
            {% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}
          </p>

          <h3 class="value-pillars__title">{{ block.settings.title }}</h3>

          {% if block.settings.text != blank %}
            <p class="value-pillars__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .value-pillars {
    padding: 84px 0;
    background: #111111;
    color: #ffffff;
  }

  .value-pillars__intro {
    max-width: 760px;
    margin: 0 auto 34px;
    text-align: center;
  }

  .value-pillars__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .value-pillars__heading {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .value-pillars__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .value-pillars__card {
    background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.02) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 24px 30px;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

.value-pillars__card {
  background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 28px 24px 30px;
  min-height: 280px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  transition:
    transform 0.3s ease,
    border-color 0.3s ease,
    box-shadow 0.3s ease,
    background 0.3s ease;
  position: relative;
  overflow: hidden;
}

.value-pillars__card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 6px;
  height: 100%;
  background: #c41230;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.value-pillars__card:hover {
  transform: translateY(-10px);
  border-color: rgba(196,18,48,0.65);
  box-shadow: 0 26px 48px rgba(0,0,0,0.26);
  background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.03) 100%);
}

.value-pillars__card:hover::before {
  opacity: 1;
}

  .value-pillars__number {
    margin: 0 0 18px;
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    font-weight: 900;
    color: #c41230;
    line-height: 1;
    text-transform: uppercase;
  }

.value-pillars__title {
  margin: 0 0 14px;
  font-family: var(--sole-heading-font);
  font-size: 2.2rem;
  line-height: 1;
  font-weight: 900;
  text-transform: uppercase;
  color: #ffffff;
  transition: color 0.3s ease, transform 0.3s ease;
}
.value-pillars__card:hover .value-pillars__title {
  color: #ffffff;
  transform: translateX(4px);
}

  .value-pillars__text {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.82);
  }

  @media screen and (max-width: 989px) {
    .value-pillars {
      padding: 64px 0;
    }

    .value-pillars__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .value-pillars__grid {
      grid-template-columns: 1fr;
    }

    .value-pillars__card {
      min-height: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Value Pillars",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Sets Us Apart"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Small Business, Big Reach"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Personalized service with the capabilities and product access to support brands of any size."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value Pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Small Business, Big Reach",
            "text": "Personalized service with the capabilities and product access to support brands of any size."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Quality First",
            "text": "From product selection to final delivery, quality stays at the center of every project."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Detail Oriented",
            "text": "The small details matter, and we treat them like they make the difference — because they do."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Relationship Focused",
            "text": "We believe every client should feel valued, supported, and treated like our top priority."
          }
        }
      ]
    }
  ]
}
{% endschema %}