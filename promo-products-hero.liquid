<section class="promo-how">
  <div class="page-width">
    <div class="promo-how__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="promo-how__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="promo-how__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="promo-how__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="promo-how__grid">
      {% for block in section.blocks %}
        <div class="promo-how__card" {{ block.shopify_attributes }}>
          <p class="promo-how__number">
            {% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}
          </p>

          <h3 class="promo-how__title">{{ block.settings.title }}</h3>

          {% if block.settings.text != blank %}
            <p class="promo-how__card-text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .promo-how {
    padding: 84px 0;
    background: #ffffff;
  }

  .promo-how__intro {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 34px;
  }

  .promo-how__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .promo-how__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .promo-how__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .promo-how__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .promo-how__card {
    background: #f5f5f5;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 18px;
    padding: 28px 22px 30px;
    min-height: 240px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .promo-how__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.12);
    border-color: rgba(196, 18, 48, 0.35);
  }

  .promo-how__number {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #c41230;
  }

  .promo-how__title {
    margin: 0 0 12px;
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .promo-how__card-text {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  @media screen and (max-width: 989px) {
    .promo-how {
      padding: 64px 0;
    }

    .promo-how__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .promo-how__grid {
      grid-template-columns: 1fr;
    }

    .promo-how__card {
      min-height: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Promo How It Works",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One Organized Quote Process"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Browse products, add what you need, and submit one organized request with quantities, notes, and details all in one place."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Browse Products"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step text",
          "default": "Explore product categories and find the items that fit your project."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Browse Products",
            "text": "Explore categories and find the items that fit your business, event, or organization."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Add to Quote",
            "text": "Select products you’re interested in and build one organized request instead of submitting multiple forms."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Add Details",
            "text": "Include quantities, artwork notes, and anything else we should know about the project."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Submit Once",
            "text": "Send everything in one request and we’ll help finalize the right products, pricing, and next steps."
          }
        }
      ]
    }
  ]
}
{% endschema %}