<section class="trusted-logos">
  <div class="page-width">
    <div class="trusted-logos__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="trusted-logos__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="trusted-logos__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="trusted-logos__marquee">
      <div class="trusted-logos__track">
        {% for block in section.blocks %}
          <div class="trusted-logos__item" {{ block.shopify_attributes }}>
            {% if block.settings.logo != blank %}
              <img
                src="{{ block.settings.logo | image_url: width: 600 }}"
                alt="{{ block.settings.name | escape }}"
                loading="lazy"
                width="{{ block.settings.logo.width }}"
                height="{{ block.settings.logo.height }}"
              >
            {% else %}
              <span>{{ block.settings.name }}</span>
            {% endif %}
          </div>
        {% endfor %}

        {% for block in section.blocks %}
          <div class="trusted-logos__item trusted-logos__item--duplicate">
            {% if block.settings.logo != blank %}
              <img
                src="{{ block.settings.logo | image_url: width: 600 }}"
                alt="{{ block.settings.name | escape }}"
                loading="lazy"
                width="{{ block.settings.logo.width }}"
                height="{{ block.settings.logo.height }}"
              >
            {% else %}
              <span>{{ block.settings.name }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .trusted-logos {
    padding: 72px 0;
    background: #ffffff;
    overflow: hidden;
  }

  .trusted-logos__intro {
    text-align: center;
    margin: 0 auto 26px;
    max-width: 760px;
  }

  .trusted-logos__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .trusted-logos__heading {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.6rem, 4vw, 4.4rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .trusted-logos__marquee {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .trusted-logos__track {
    display: flex;
    align-items: center;
    gap: 54px;
    width: max-content;
    animation: trustedLogosScroll 30s linear infinite;
  }

  .trusted-logos__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 140px;
    max-width: 220px;
    height: 92px;
    flex: 0 0 auto;
  }

  .trusted-logos__item img {
    max-width: 100%;
    max-height: 72px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .trusted-logos__item span {
    font-family: var(--sole-heading-font);
    font-size: 1.8rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    text-align: center;
  }

  @keyframes trustedLogosScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .trusted-logos {
      padding: 56px 0;
    }

    .trusted-logos__track {
      gap: 34px;
      animation-duration: 24s;
    }

    .trusted-logos__item {
      min-width: 110px;
      max-width: 180px;
      height: 76px;
    }

    .trusted-logos__item img {
      max-height: 56px;
    }
  }
</style>

{% schema %}
{
  "name": "Trusted By Logos",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Social Proof"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted By"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Client Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted By Logos"
    }
  ]
}
{% endschema %}