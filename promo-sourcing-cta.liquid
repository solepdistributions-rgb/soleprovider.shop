<section class="promo-quote-cta">
  <div class="page-width">
    <div class="promo-quote-cta__card">
      {% if section.settings.eyebrow != blank %}
        <p class="promo-quote-cta__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="promo-quote-cta__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="promo-quote-cta__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="promo-quote-cta__buttons">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a href="{{ section.settings.primary_link }}" class="promo-quote-cta__button promo-quote-cta__button--primary">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a href="{{ section.settings.secondary_link }}" class="promo-quote-cta__button promo-quote-cta__button--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .promo-quote-cta {
    padding: 84px 0;
    background: #111111;
  }

  .promo-quote-cta__card {
    max-width: 980px;
    margin: 0 auto;
    padding: 52px 40px;
    text-align: center;
    background: linear-gradient(135deg, #111111 0%, #1a1a1a 68%, #c41230 155%);
    border-radius: 24px;
    box-shadow: 0 24px 54px rgba(0, 0, 0, 0.2);
  }

  .promo-quote-cta__eyebrow {
    margin: 0 0 10px;
    color: rgba(255,255,255,0.86);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .promo-quote-cta__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 5rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .promo-quote-cta__text {
    margin: 0 auto 24px;
    max-width: 64rem;
    font-size: 1.7rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.9);
  }

  .promo-quote-cta__buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  .promo-quote-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid transparent;
    transition: all 0.25s ease;
  }

  .promo-quote-cta__button--primary {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  .promo-quote-cta__button--primary:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .promo-quote-cta__button--secondary {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .promo-quote-cta__button--secondary:hover {
    background: #ffffff;
    color: #111111;
  }

  @media screen and (max-width: 989px) {
    .promo-quote-cta {
      padding: 64px 0;
    }

    .promo-quote-cta__card {
      padding: 38px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Quote CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Organized Ordering"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build One Organized Quote"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Add multiple items, keep your order organized, and submit one quote request for everything at once."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Start a Quote"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Promo Quote CTA"
    }
  ]
}
{% endschema %}