<section class="ap-process">
  <div class="page-width">
    <div class="ap-process__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="ap-process__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ap-process__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    <div class="ap-process__steps">
      {% for block in section.blocks %}
        <div class="ap-process__step" {{ block.shopify_attributes }}>
          <div class="ap-process__num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</div>
          <div class="ap-process__step-body">
            <h3 class="ap-process__step-title">{{ block.settings.title }}</h3>
            {% if block.settings.text != blank %}
              <p class="ap-process__step-text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
        {% unless forloop.last %}
          <div class="ap-process__connector" aria-hidden="true"></div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ap-process { padding: 84px 0; background: #111111; color: #ffffff; }
  .ap-process__intro { text-align: center; max-width: 680px; margin: 0 auto 52px; }
  .ap-process__eyebrow { margin: 0 0 10px; color: rgba(255,255,255,0.7); font-size: 1.2rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; }
  .ap-process__heading { margin: 0; font-family: var(--sole-heading-font); font-size: clamp(2.8rem, 4vw, 4.8rem); line-height: 0.95; font-weight: 900; text-transform: uppercase; color: #ffffff; }

  .ap-process__steps { display: flex; align-items: flex-start; }
  .ap-process__step { flex: 1; padding: 32px 24px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); transition: background 0.28s ease, border-color 0.28s ease, transform 0.28s ease; }
  .ap-process__step:hover { background: rgba(196,18,48,0.1); border-color: rgba(196,18,48,0.45); transform: translateY(-4px); }
  .ap-process__connector { width: 32px; flex-shrink: 0; height: 2px; background: rgba(196,18,48,0.5); align-self: center; position: relative; }
  .ap-process__connector::after { content: ''; position: absolute; right: -5px; top: 50%; transform: translateY(-50%); width: 0; height: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent; border-left: 7px solid rgba(196,18,48,0.5); }
  .ap-process__num { font-family: var(--sole-heading-font); font-size: 3.2rem; font-weight: 900; color: #c41230; line-height: 1; margin-bottom: 14px; }
  .ap-process__step-title { margin: 0 0 10px; font-family: var(--sole-heading-font); font-size: 1.9rem; line-height: 1.05; font-weight: 900; text-transform: uppercase; color: #ffffff; }
  .ap-process__step-text { margin: 0; font-size: 1.45rem; line-height: 1.65; color: rgba(255,255,255,0.72); }

  @media screen and (max-width: 989px) {
    .ap-process { padding: 64px 0; }
    .ap-process__steps { flex-direction: column; }
    .ap-process__connector { width: 2px; height: 28px; align-self: auto; margin: 0 32px; }
    .ap-process__connector::after { right: 50%; bottom: -5px; top: auto; transform: translateX(50%); border-top: 7px solid rgba(196,18,48,0.5); border-left: 5px solid transparent; border-right: 5px solid transparent; border-bottom: none; }
  }
</style>

{% schema %}
{
  "name": "Apparel Process",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How It Works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Idea to Delivery" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Step title", "default": "Submit Your Request" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Tell us what you need and we handle the rest." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Apparel Process",
      "blocks": [
        { "type": "step", "settings": { "title": "Submit Your Request", "text": "Share your idea — quantity, style, decoration, and timeline — through our quote form." } },
        { "type": "step", "settings": { "title": "Review Your Quote", "text": "We send a detailed quote with pricing, product options, and production timeline." } },
        { "type": "step", "settings": { "title": "Approve & Submit Artwork", "text": "Approve the quote and submit your artwork. Need design help? We've got you covered." } },
        { "type": "step", "settings": { "title": "Production & Delivery", "text": "We manage production and ship directly to you or your team. Simple." } }
      ]
    }
  ]
}
{% endschema %}