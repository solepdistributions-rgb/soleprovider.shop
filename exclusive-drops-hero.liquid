{% assign featured_product = all_products[section.settings.product] %}

<section class="drops-feature" id="current-drop">
  <div class="page-width">
    <div class="drops-feature__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="drops-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="drops-feature__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="drops-feature__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    {% if featured_product != blank %}
      {% assign current_variant = featured_product.selected_or_first_available_variant %}

      <div class="drops-feature__card">
        <div class="drops-feature__media">
          <a href="{{ featured_product.url }}">
            {% if featured_product.featured_image != blank %}
              <img
                src="{{ featured_product.featured_image | image_url: width: 1600 }}"
                alt="{{ featured_product.title | escape }}"
                loading="lazy"
                width="{{ featured_product.featured_image.width }}"
                height="{{ featured_product.featured_image.height }}"
              >
            {% else %}
              <div class="drops-feature__placeholder">
                <span>{{ featured_product.title }}</span>
              </div>
            {% endif %}
          </a>
        </div>

        <div class="drops-feature__content">
          {% if section.settings.badge_text != blank %}
            <p class="drops-feature__badge">{{ section.settings.badge_text }}</p>
          {% endif %}

          <h3 class="drops-feature__product-title">
            <a href="{{ featured_product.url }}">{{ featured_product.title }}</a>
          </h3>

          <div class="drops-feature__price" id="DropsPrice-{{ section.id }}">
            {% render 'price', product: featured_product, use_variant: true, show_badges: false, price_class: 'price--large' %}
          </div>

          {% if section.settings.show_description and featured_product.description != blank %}
            <div class="drops-feature__description rte">
              {{ featured_product.description }}
            </div>
          {% elsif section.settings.custom_text != blank %}
            <div class="drops-feature__description rte">
              {{ section.settings.custom_text }}
            </div>
          {% endif %}

          {%- form 'product', featured_product, class: 'drops-feature__form', novalidate: 'novalidate' -%}
            <input
              type="hidden"
              name="id"
              value="{{ current_variant.id }}"
              class="drops-feature__variant-id"
            >

            {% unless featured_product.has_only_default_variant %}
              <div class="drops-feature__options">
                {% for option in featured_product.options_with_values %}
                  <div class="drops-feature__option">
                    <label class="drops-feature__option-label" for="DropsOption-{{ section.id }}-{{ forloop.index0 }}">
                      {{ option.name }}
                    </label>

                    <select
                      id="DropsOption-{{ section.id }}-{{ forloop.index0 }}"
                      class="drops-feature__select"
                      data-option-index="{{ forloop.index0 }}"
                    >
                      {% for value in option.values %}
                        <option
                          value="{{ value | escape }}"
                          {% if option.selected_value == value %}selected{% endif %}
                        >
                          {{ value }}
                        </option>
                      {% endfor %}
                    </select>
                  </div>
                {% endfor %}
              </div>

              <script type="application/json" id="DropsProductData-{{ section.id }}">
                {{ featured_product.variants | json }}
              </script>
            {% endunless %}

            <div class="drops-feature__actions">
              <div class="drops-feature__qty-wrap">
                <label class="drops-feature__option-label" for="DropsQuantity-{{ section.id }}">Quantity</label>
                <input
                  id="DropsQuantity-{{ section.id }}"
                  class="drops-feature__qty"
                  type="number"
                  name="quantity"
                  min="1"
                  value="1"
                >
              </div>

              <div class="drops-feature__buttons">
                <button
                  type="submit"
                  name="add"
                  class="drops-feature__button drops-feature__button--primary"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  {% if current_variant.available %}
                    Add to Cart
                  {% else %}
                    Sold Out
                  {% endif %}
                </button>

                <a href="{{ featured_product.url }}" class="drops-feature__button drops-feature__button--secondary">
                  View Product
                </a>
              </div>
            </div>
          {%- endform -%}

          {% if section.settings.note != blank %}
            <p class="drops-feature__note">{{ section.settings.note }}</p>
          {% endif %}
        </div>
      </div>
    {% else %}
      <div class="drops-feature__empty">
        <h3>No drop selected yet</h3>
        <p>Choose a product in the theme editor to feature the current monthly drop here.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .drops-feature {
    padding: 84px 0;
    background: #ffffff;
    color: #111111;
  }

  .drops-feature__intro {
    max-width: 760px;
    margin: 0 auto 34px;
    text-align: center;
  }

  .drops-feature__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .drops-feature__heading {
    margin: 0 0 12px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.9rem, 4vw, 5rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .drops-feature__text {
    font-size: 1.55rem;
    line-height: 1.75;
    color: #555555;
  }

  .drops-feature__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
    gap: 30px;
    align-items: start;
    background: #ffffff;
    border: 1px solid #e4e4e4;
    box-shadow: 0 8px 0 #d9d9d9, 0 18px 36px rgba(0,0,0,0.06);
    padding: 28px;
  }

  .drops-feature__media img,
  .drops-feature__placeholder {
    display: block;
    width: 100%;
    border-radius: 18px;
    overflow: hidden;
    background: #f4f4f4;
  }

  .drops-feature__media img {
    height: auto;
    object-fit: cover;
  }

  .drops-feature__placeholder {
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: linear-gradient(135deg, #ececec 0%, #dcdcdc 100%);
  }

  .drops-feature__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 2.4rem;
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
  }

  .drops-feature__badge {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .drops-feature__product-title {
    margin: 0 0 10px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.6rem, 3vw, 4.2rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
  }

  .drops-feature__product-title a {
    color: inherit;
    text-decoration: none;
  }

  .drops-feature__price {
    margin-bottom: 18px;
  }

  .drops-feature__description {
    margin-bottom: 22px;
    font-size: 1.5rem;
    line-height: 1.75;
    color: #444444;
  }

  .drops-feature__options {
    display: grid;
    gap: 14px;
    margin-bottom: 20px;
  }

  .drops-feature__option-label {
    display: block;
    margin-bottom: 8px;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .drops-feature__select,
  .drops-feature__qty {
    width: 100%;
    min-height: 48px;
    padding: 0 14px;
    border: 1px solid #d8d8d8;
    background: #ffffff;
    color: #111111;
    font-size: 1.45rem;
    box-sizing: border-box;
  }

  .drops-feature__actions {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 16px;
    align-items: end;
  }

  .drops-feature__buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .drops-feature__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 22px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.22s ease;
  }

  .drops-feature__button--primary {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .drops-feature__button--primary:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  .drops-feature__button--secondary {
    background: transparent;
    color: #111111;
    border-color: #111111;
  }

  .drops-feature__button--secondary:hover {
    background: #111111;
    color: #ffffff;
  }

  .drops-feature__button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .drops-feature__note {
    margin: 18px 0 0;
    font-size: 1.3rem;
    line-height: 1.6;
    color: #666666;
  }

  .drops-feature__empty {
    padding: 28px;
    text-align: center;
    border: 1px solid #e4e4e4;
    background: #f8f8f8;
  }

  @media screen and (max-width: 989px) {
    .drops-feature {
      padding: 64px 0;
    }

    .drops-feature__card {
      grid-template-columns: 1fr;
    }

    .drops-feature__actions {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .drops-feature__buttons {
      flex-direction: column;
    }

    .drops-feature__button {
      width: 100%;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var form = document.querySelector('.drops-feature__form');
    var productDataEl = document.getElementById('DropsProductData-' + sectionId);
    var variantIdInput = document.querySelector('.drops-feature__variant-id');
    var priceWrap = document.getElementById('DropsPrice-' + sectionId);

    if (!form || !productDataEl || !variantIdInput) return;

    var variants = JSON.parse(productDataEl.textContent);
    var selectors = form.querySelectorAll('[data-option-index]');

    function moneyFormat(cents) {
      return Shopify.formatMoney(cents, "{{ shop.money_format | escape }}");
    }

    function findVariant() {
      var selectedOptions = [];

      selectors.forEach(function(select) {
        selectedOptions.push(select.value);
      });

      return variants.find(function(variant) {
        return variant.options.every(function(option, index) {
          return option === selectedOptions[index];
        });
      });
    }

    function updateVariant() {
      var variant = findVariant();
      if (!variant) return;

      variantIdInput.value = variant.id;

      var submitButton = form.querySelector('[type="submit"][name="add"]');
      if (submitButton) {
        submitButton.disabled = !variant.available;
        submitButton.textContent = variant.available ? 'Add to Cart' : 'Sold Out';
      }

      if (priceWrap && variant.price) {
        priceWrap.innerHTML = '<div class="price price--large"><div class="price__container"><div class="price__regular"><span class="visually-hidden">Regular price</span><span class="price-item price-item--regular">' + moneyFormat(variant.price) + '</span></div></div></div>';
      }
    }

    selectors.forEach(function(select) {
      select.addEventListener('change', updateVariant);
    });
  })();
</script>

{% schema %}
{
  "name": "Exclusive Drops Feature",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Current Drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Current Release"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>A featured Sole Provider release available to purchase directly while it lasts.</p>"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Monthly Drop"
    },
    {
      "type": "richtext",
      "id": "custom_text",
      "label": "Custom text override",
      "default": "<p>Limited release. Once it’s gone, it may not return in the same form again.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description instead of custom text",
      "default": true
    },
    {
      "type": "text",
      "id": "note",
      "label": "Small note",
      "default": "Limited quantities available. Product availability may change without notice."
    }
  ],
  "presets": [
    {
      "name": "Exclusive Drops Feature"
    }
  ]
}
{% endschema %}