            "title": "Graphic Design Services",
            "text": "Creative support for apparel, branding, print pieces, and promotional visuals.",
            "cta_text": "View Design",
            "icon_text": "GD"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Portfolio",
            "text": "See past work, creative projects, and branding examples.",
            "cta_text": "View Work",
            "icon_text": "PF"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Exclusive Drops",
            "text": "Shop Sole Provider products, featured pieces, and exclusive releases.",
            "cta_text": "Shop Drops",
            "icon_text": "XD"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Team Stores",
            "text": "Shop active stores for schools, teams, organizations, and group orders.",
            "cta_text": "View Stores",
            "icon_text": "TS"
          }
        },
        {
          "type": "card",
          "settings": {
