<section class="brand-story">
  <div class="page-width">
    <div class="brand-story__grid">
      <div class="brand-story__content">
        {% if section.settings.eyebrow != blank %}
          <p class="brand-story__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="brand-story__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.paragraph_1 != blank %}
          <p class="brand-story__text">{{ section.settings.paragraph_1 }}</p>
        {% endif %}

        {% if section.settings.paragraph_2 != blank %}
          <p class="brand-story__text">{{ section.settings.paragraph_2 }}</p>
        {% endif %}

        {% if section.settings.paragraph_3 != blank %}
          <p class="brand-story__text">{{ section.settings.paragraph_3 }}</p>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="brand-story__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <div class="brand-story__media">
        {% if section.settings.logo_image != blank %}
          <div class="brand-story__logo-panel">
            <img
              src="{{ section.settings.logo_image | image_url: width: 1200 }}"
              alt="{{ section.settings.logo_image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.logo_image.width }}"
              height="{{ section.settings.logo_image.height }}"
            >
          </div>
        {% else %}
          <div class="brand-story__logo-panel brand-story__logo-panel--placeholder">
            <span>{{ section.settings.placeholder_text }}</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .brand-story {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .brand-story__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: center;
  }

  .brand-story__content {
    max-width: 760px;
  }

  .brand-story__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .brand-story__heading {
    margin: 0 0 20px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .brand-story__text {
    margin: 0 0 18px;
    font-size: 1.65rem;
    line-height: 1.75;
    color: #3f3f3f;
    max-width: 64rem;
  }

  .brand-story__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 22px;
    margin-top: 10px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: #111111;
    color: #ffffff;
    border: 2px solid #111111;
    transition: all 0.25s ease;
  }

  .brand-story__button:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  .brand-story__media {
    display: flex;
    justify-content: center;
  }

  .brand-story__logo-panel {
    width: 100%;
    max-width: 520px;
    min-height: 420px;
    background: linear-gradient(135deg, #111111 0%, #1f1f1f 70%, #c41230 130%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.12);
  }

  .brand-story__logo-panel img {
    display: block;
    max-width: 100%;
    max-height: 300px;
    width: auto;
    height: auto;
    object-fit: contain;
    background: #ffffff;
    padding: 16px;
    border-radius: 12px;
  }

  .brand-story__logo-panel--placeholder span {
    font-family: var(--sole-heading-font);
    font-size: clamp(2.2rem, 4vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    line-height: 1;
  }

  @media screen and (max-width: 989px) {
    .brand-story {
      padding: 64px 0;
    }

    .brand-story__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .brand-story__logo-panel {
      min-height: 320px;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More Than a Name"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "The Sole Provider started as a sneaker resale business, but over time it grew into something much bigger. What began with a passion for product, style, and culture evolved into a full-service promotional branding agency built to make things easier for the people we work with."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Today, the name represents what we aim to be for every client: a one-stop source for custom apparel, branded items, creative design, and promotional support. We focus on quality, detail, and service at every step, while keeping the process approachable and affordable."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "At its core, The Sole Provider is about more than products. It is about helping people feel seen, supported, and confident that their vision is being handled with real care."
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "The Sole Provider"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View on Instagram"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}