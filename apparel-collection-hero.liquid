<section class="ap-cats" id="apparel-categories">
  <div class="page-width">
    <div class="ap-cats__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="ap-cats__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ap-cats__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="ap-cats__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="ap-cats__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="ap-cats__card" {{ block.shopify_attributes }}>
          <div class="ap-cats__media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {% else %}
              <div class="ap-cats__placeholder"><span>{{ block.settings.icon_text }}</span></div>
            {% endif %}
          </div>

          <div class="ap-cats__overlay">
            <div class="ap-cats__card-body">
              <h3 class="ap-cats__title">{{ block.settings.title }}</h3>
              {% if block.settings.subtitle != blank %}
                <p class="ap-cats__subtitle">{{ block.settings.subtitle }}</p>
              {% endif %}
              <span class="ap-cats__arrow">Explore Category →</span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ap-cats {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .ap-cats__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 48px;
  }

  .ap-cats__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ap-cats__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .ap-cats__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .ap-cats__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }

  .ap-cats__card {
    position: relative;
    display: block;
    min-height: 300px;
    overflow: hidden;
    text-decoration: none;
    background: #111111;
    border: 1px solid #d0d0d0;
    border-bottom: 4px solid #aaaaaa;
    box-shadow: 0 6px 0 #999999, 0 10px 24px rgba(0,0,0,0.12);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .ap-cats__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 14px 0 #888888, 0 22px 40px rgba(0,0,0,0.18);
    border-color: #c41230;
    border-bottom-color: #9a0e24;
  }

  .ap-cats__media {
    position: absolute;
    inset: 0;
  }

  .ap-cats__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ap-cats__card:hover .ap-cats__media img {
    transform: scale(1.05);
  }

  .ap-cats__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #c41230 130%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ap-cats__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
  }

  .ap-cats__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,17,0.92) 0%, rgba(17,17,17,0.45) 45%, rgba(17,17,17,0.05) 100%);
    display: flex;
    align-items: flex-end;
    transition: background 0.3s ease;
  }

  .ap-cats__card:hover .ap-cats__overlay {
    background: linear-gradient(to top, rgba(196,18,48,0.88) 0%, rgba(17,17,17,0.55) 50%, rgba(17,17,17,0.1) 100%);
  }

  .ap-cats__card-body {
    padding: 24px 20px 20px;
    width: 100%;
  }

  .ap-cats__title {
    margin: 0 0 6px;
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .ap-cats__subtitle {
    margin: 0 0 12px;
    font-size: 1.35rem;
    line-height: 1.45;
    color: rgba(255,255,255,0.74);
  }

  .ap-cats__arrow {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.55);
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .ap-cats__card:hover .ap-cats__arrow {
    color: #ffffff;
    transform: translateX(4px);
  }

  @media screen and (max-width: 1199px) {
    .ap-cats__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .ap-cats {
      padding: 64px 0;
    }

    .ap-cats__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ap-cats__card {
      min-height: 260px;
    }
  }

  @media screen and (max-width: 749px) {
    .ap-cats__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .ap-cats__card {
      min-height: 200px;
    }

    .ap-cats__title {
      font-size: 1.8rem;
    }

    .ap-cats__subtitle {
      font-size: 1.2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Apparel Categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop By Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse Apparel" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Start with a category, then narrow your options by style, brand, color, size, and material." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "icon_text", "label": "Icon fallback (no image)", "default": "TS" },
        { "type": "text", "id": "title", "label": "Title", "default": "T-Shirts" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Basics, performance, heavyweight, and long sleeve styles" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Apparel Categories",
      "blocks": [
        { "type": "category", "settings": { "icon_text": "TS", "title": "T-Shirts", "subtitle": "Basics, performance, heavyweight, and long sleeve styles", "link": "/collections/t-shirts" } },
        { "type": "category", "settings": { "icon_text": "PL", "title": "Polos", "subtitle": "Performance, cotton, and work-ready options", "link": "/collections/polos" } },
        { "type": "category", "settings": { "icon_text": "DS", "title": "Dress Shirts", "subtitle": "Woven, stretch, and easy-care dress shirt options", "link": "/collections/dress-shirts" } },
        { "type": "category", "settings": { "icon_text": "SW", "title": "Sweatshirts", "subtitle": "Hoodies, crewnecks, quarter-zips, and full-zips", "link": "/collections/sweatshirts" } },
        { "type": "category", "settings": { "icon_text": "OW", "title": "Outerwear", "subtitle": "Lightweight jackets, soft shells, fleece, vests, and rainwear", "link": "/collections/outerwear" } },
        { "type": "category", "settings": { "icon_text": "BT", "title": "Bottoms", "subtitle": "Joggers, shorts, athletic bottoms, and workwear bottoms", "link": "/collections/bottoms" } },
        { "type": "category", "settings": { "icon_text": "HW", "title": "Headwear", "subtitle": "Caps, beanies, and performance headwear", "link": "/collections/headwear" } }
      ]
    }
  ]
}
{% endschema %}