<section class="ap-hero">
  <div class="page-width">
    <div class="ap-hero__grid">
      <div class="ap-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="ap-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="ap-hero__heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="ap-hero__text">{{ section.settings.text }}</p>
        {% endif %}
        <div class="ap-hero__buttons">
          {% if section.settings.primary_label != blank %}
            <a href="{{ section.settings.primary_link }}" class="ap-btn ap-btn--primary">{{ section.settings.primary_label }}</a>
          {% endif %}
          {% if section.settings.secondary_label != blank %}
            <a href="{{ section.settings.secondary_link }}" class="ap-btn ap-btn--secondary">{{ section.settings.secondary_label }}</a>
          {% endif %}
        </div>
      </div>
      <div class="ap-hero__media">
        {% if section.settings.hero_image != blank %}
          <img src="{{ section.settings.hero_image | image_url: width: 1800 }}" alt="{{ section.settings.heading | escape }}" loading="eager" width="{{ section.settings.hero_image.width }}" height="{{ section.settings.hero_image.height }}" class="ap-hero__img">
        {% else %}
          <div class="ap-hero__placeholder"><span>Custom Apparel</span></div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .ap-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 26px; text-decoration: none; text-transform: uppercase; font-weight: 800; font-size: 1.4rem; letter-spacing: 0.06em; border: 2px solid transparent; transition: all 0.25s ease; }
  .ap-btn--primary { background: #c41230; color: #ffffff; border-color: #c41230; }
  .ap-btn--primary:hover { background: #111111; border-color: #111111; color: #ffffff; }
  .ap-btn--secondary { background: transparent; color: #ffffff; border-color: rgba(255,255,255,0.6); }
  .ap-btn--secondary:hover { background: #ffffff; color: #111111; border-color: #ffffff; }

  .ap-hero { padding: 84px 0; background: linear-gradient(135deg, #111111 0%, #171717 55%, #c41230 165%); color: #ffffff; }
  .ap-hero__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .ap-hero__eyebrow { margin: 0 0 12px; color: rgba(255,255,255,0.75); font-size: 1.2rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; }
  .ap-hero__heading { margin: 0 0 18px; font-family: var(--sole-heading-font); font-size: clamp(3.6rem, 5.5vw, 6.4rem); line-height: 0.93; font-weight: 900; text-transform: uppercase; color: #ffffff; }
  .ap-hero__text { margin: 0 0 28px; font-size: 1.7rem; line-height: 1.7; color: rgba(255,255,255,0.85); max-width: 54rem; }
  .ap-hero__buttons { display: flex; flex-wrap: wrap; gap: 14px; }
  .ap-hero__media { position: relative; border-radius: 16px; overflow: hidden; aspect-ratio: 4 / 3; box-shadow: 0 32px 64px rgba(0,0,0,0.38); }
  .ap-hero__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ap-hero__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1a1a1a 0%, #c41230 100%); }
  .ap-hero__placeholder span { font-family: var(--sole-heading-font); font-size: 3rem; font-weight: 900; text-transform: uppercase; color: rgba(255,255,255,0.9); }

  @media screen and (max-width: 989px) {
    .ap-hero { padding: 64px 0; }
    .ap-hero__grid { grid-template-columns: 1fr; gap: 36px; }
    .ap-hero__media { aspect-ratio: 16 / 9; }
  }
</style>

{% schema %}
{
  "name": "Apparel Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Custom Apparel" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Apparel Built For Your Brand" },
    { "type": "textarea", "id": "text", "label": "Subtext", "default": "From corporate polos to streetwear drops, we handle custom apparel from concept to delivery." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "primary_label", "label": "Primary button", "default": "Request a Quote" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button", "default": "View Portfolio" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Apparel Hero" }]
}
{% endschema %}