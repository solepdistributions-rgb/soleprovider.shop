<section class="sole-hero">
  <div class="sole-hero__inner page-width">
    <div class="sole-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="sole-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      <h1 class="sole-hero__title">{{ section.settings.heading }}</h1>

      {% if section.settings.subheading != blank %}
        <div class="sole-hero__subheading">
          <p>{{ section.settings.subheading }}</p>
        </div>
      {% endif %}

      <div class="sole-hero__buttons">
        {% if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank %}
          <a href="{{ section.settings.primary_button_link }}" class="sole-hero__button sole-hero__button--primary">
            {{ section.settings.primary_button_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank %}
          <a href="{{ section.settings.secondary_button_link }}" class="sole-hero__button sole-hero__button--secondary">
            {{ section.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="sole-hero__media">
      {% if section.settings.hero_image != blank %}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1800 }}"
          alt="{{ section.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
        >
      {% else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'sole-hero__placeholder' }}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .sole-hero {
    background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 55%, #111111 100%);
    color: #ffffff;
    padding: 72px 0;
    position: relative;
    overflow: hidden;
  }

  .sole-hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 28%;
    height: 100%;
    background: rgba(196, 18, 48, 0.16);
    transform: skewX(-18deg) translateX(22%);
    pointer-events: none;
  }

  .sole-hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 48px;
    position: relative;
    z-index: 1;
  }

  .sole-hero__content {
    max-width: 680px;
  }

 .sole-hero__eyebrow {
  margin: 0 0 10px;
  color: #ffffff;
  font-family: var(--sole-heading-font);
  font-size: clamp(2.2rem, 4vw, 4.2rem);
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1;
}
  }

.sole-hero .sole-hero__title,
.sole-hero h1.sole-hero__title {
  margin: 0 0 16px;
  font-family: var(--sole-heading-font);
  font-size: clamp(3.8rem, 7vw, 7rem);
  line-height: 0.92;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -0.03em;
  color: #c41230 !important;
  max-width: 12ch;
}
.sole-hero .sole-hero__content h1 {
  color: #c41230 !important;
  font-weight: 900 !important;
  letter-spacing: -0.05em;
}
.sole-hero__subheading p {
  margin: 0;
  font-size: 1.7rem;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
}

  .sole-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .sole-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 22px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: 2px solid transparent;
    transition: all 0.25s ease;
  }

  .sole-hero__button--primary {
    background: #c41230;
    color: #ffffff;
  }

  .sole-hero__button--primary:hover {
    background: #ffffff;
    color: #111111;
  }

  .sole-hero__button--secondary {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .sole-hero__button--secondary:hover {
    background: #ffffff;
    color: #111111;
  }

  .sole-hero__media {
    position: relative;
  }

  .sole-hero__media img,
  .sole-hero__placeholder {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 18px;
    object-fit: cover;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
  }

  @media screen and (max-width: 989px) {
    .sole-hero {
      padding: 56px 0;
    }

    .sole-hero__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .sole-hero__content {
      max-width: 100%;
    }

    .sole-hero__title {
      font-size: clamp(2.8rem, 9vw, 4.8rem);
    }

    .sole-hero__subheading p {
      font-size: 1.6rem;
    }
  }
</style>

{% schema %}
{
  "name": "Sole Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Sole Provider"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where Business Meets Creativity"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From corporate branding to creative drops, we bring your vision to life."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Request Quote"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "View Portfolio"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Sole Hero"
    }
  ]
}
{% endschema %}