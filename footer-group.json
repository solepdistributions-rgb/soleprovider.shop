<section class="final-cta">
  <div class="page-width">
    <div class="final-cta__card">
      {% if section.settings.eyebrow != blank %}
        <p class="final-cta__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="final-cta__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="final-cta__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="final-cta__buttons">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a href="{{ section.settings.primary_link }}" class="final-cta__button final-cta__button--primary">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a href="{{ section.settings.secondary_link }}" class="final-cta__button final-cta__button--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 84px 0;
    background: #111111;
  }

  .final-cta__card {
    position: relative;
    overflow: hidden;
    max-width: 980px;
    margin: 0 auto;
    padding: 56px 44px;
    text-align: center;
    background: linear-gradient(135deg, #111111 0%, #1b1b1b 70%, #c41230 150%);
    border-radius: 24px;
    box-shadow: 0 24px 54px rgba(0, 0, 0, 0.22);
  }

  .final-cta__card::before {
    content: "";
    position: absolute;
    top: -30%;
    left: -45%;
    width: 32%;
    height: 170%;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.18) 45%,
      rgba(255, 255, 255, 0.35) 50%,
      rgba(196, 18, 48, 0.20) 55%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(18deg);
    opacity: 0;
    pointer-events: none;
    z-index: 2;
  }

  .final-cta__card:hover::before {
    animation: finalCtaSheen 1.15s ease forwards;
  }

  .final-cta__card > * {
    position: relative;
    z-index: 3;
  }

  @keyframes finalCtaSheen {
    0% {
      left: -45%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    100% {
      left: 125%;
      opacity: 0;
    }
  }

  .final-cta__eyebrow {
    margin: 0 0 10px;
    color: #ffffff;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.86;
  }

  .final-cta__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3rem, 5vw, 5.6rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .final-cta__text {
    margin: 0 auto 24px;
    max-width: 66rem;
    font-size: 1.7rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.88);
  }

  .final-cta__buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  .final-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid transparent;
    transition: all 0.25s ease;
  }

  .final-cta__button--primary {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  .final-cta__button--primary:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .final-cta__button--secondary {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .final-cta__button--secondary:hover {
    background: #ffffff;
    color: #111111;
  }

  @media screen and (max-width: 989px) {
    .final-cta {
      padding: 64px 0;
    }

    .final-cta__card {
      padding: 40px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Let’s Build"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to Build Something Great?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "From apparel and promotional products to design support and team stores, The Sole Provider is built to help bring your vision to life."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Request Quote"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}