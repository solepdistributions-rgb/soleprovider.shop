<section class="gd-work" id="gd-work">
  <div class="page-width">
    <div class="gd-work__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="gd-work__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="gd-work__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="gd-work__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="gd-work__grid">
      {% for block in section.blocks %}
        {% if block.type == 'piece' %}
          <div class="gd-work__item gd-work__item--{{ block.settings.size }}" {{ block.shopify_attributes }}>
            <div class="gd-work__media">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div class="gd-work__placeholder">
                  <span>{{ block.settings.title }}</span>
                </div>
              {% endif %}
            </div>

            <div class="gd-work__overlay">
              <div class="gd-work__item-body">
                <strong class="gd-work__item-title">{{ block.settings.title }}</strong>

                {% if block.settings.category != blank %}
                  <span class="gd-work__item-cat">{{ block.settings.category }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .gd-work {
    padding: 84px 0;
    background: #111111;
  }

  .gd-work__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 48px;
  }

  .gd-work__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .gd-work__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .gd-work__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
  }

  .gd-work__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 280px;
    gap: 16px;
  }

  .gd-work__item {
    position: relative;
    overflow: hidden;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.06);
    cursor: default;
  }

  .gd-work__item--wide {
    grid-column: span 2;
  }

  .gd-work__item--tall {
    grid-row: span 2;
  }

  .gd-work__media {
    position: absolute;
    inset: 0;
  }

  .gd-work__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .gd-work__item:hover .gd-work__media img {
    transform: scale(1.05);
  }

  .gd-work__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 50%, rgba(196,18,48,0.2) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gd-work__placeholder span {
    padding: 0 20px;
    text-align: center;
    font-family: var(--sole-heading-font);
    font-size: 1.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.15);
  }

  .gd-work__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(to top, rgba(17,17,17,0.9) 0%, rgba(17,17,17,0.3) 40%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gd-work__item:hover .gd-work__overlay {
    opacity: 1;
  }

  .gd-work__item-body {
    width: 100%;
    padding: 20px;
  }

  .gd-work__item-title {
    display: block;
    margin-bottom: 4px;
    font-family: var(--sole-heading-font);
    font-size: 1.9rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .gd-work__item-cat {
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c41230;
  }

  @media screen and (max-width: 989px) {
    .gd-work {
      padding: 64px 0;
    }

    .gd-work__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 220px;
    }

    .gd-work__item--wide {
      grid-column: span 2;
    }

    .gd-work__item--tall {
      grid-row: span 1;
    }
  }

  @media screen and (max-width: 749px) {
    .gd-work__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }

    .gd-work__item--wide {
      grid-column: span 1;
    }
  }
</style>

{% schema %}
{
  "name": "Graphic Design Work",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Work"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed In-House, Built to Last"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A sample of logos, brand work, and print art created by The Sole Provider design team."
    }
  ],
  "blocks": [
    {
      "type": "piece",
      "name": "Work Sample",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Brand Identity"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Logo Design"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Grid size",
          "options": [
            {
              "value": "normal",
              "label": "Normal (1x1)"
            },
            {
              "value": "wide",
              "label": "Wide (2x1)"
            },
            {
              "value": "tall",
              "label": "Tall (1x2)"
            }
          ],
          "default": "normal"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Graphic Design Work",
      "blocks": [
        {
          "type": "piece",
          "settings": {
            "title": "Brand Identity Project",
            "category": "Logo Design",
            "size": "wide"
          }
        },
        {
          "type": "piece",
          "settings": {
            "title": "Apparel Print Art",
            "category": "Screen Print",
            "size": "normal"
          }
        },
        {
          "type": "piece",
          "settings": {
            "title": "Event Signage",
            "category": "Print Design",
            "size": "tall"
          }
        },
        {
          "type": "piece",
          "settings": {
            "title": "Embroidery Digitizing",
            "category": "Embroidery Art",
            "size": "normal"
          }
        },
        {
          "type": "piece",
          "settings": {
            "title": "Corporate Package",
            "category": "Brand Identity",
            "size": "normal"
          }
        },
        {
          "type": "piece",
          "settings": {
            "title": "Team Logo Redesign",
            "category": "Logo Design",
            "size": "wide"
          }
        }
      ]
    }
  ]
}
{% endschema %}