        "placeholder_text": "The Sole Provider",
        "button_label": "View on Instagram",
        "button_link": "https://www.instagram.com/the_sole_provider_?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
