    "brand_story_td4Ntt": {
      "type": "brand-story",
      "name": "Brand Story",
      "settings": {
        "eyebrow": "Built With Purpose",
        "heading": "More Than a Name",
        "paragraph_1": "The Sole Provider was founded in 2021 with $125 as a sneaker resale company. The name and slogans were dreamed up by Sean and his father at a brewery in Burlington, VT. Over time, The Sole Provider grew in the industry, becoming a well known name in the sneaker world. What began with a passion for product, style, and culture evolved into a full-service promotional branding agency. Built to make things easier for our clients.",
        "paragraph_2": "Today, the name represents what we aim to be for every client: a one-stop source for custom apparel, branded items, creative design, and promotional support. We focus on quality, detail, and service at every step, while keeping the process approachable and affordable.",
        "paragraph_3": "At its core, The Sole Provider is about more than products. It is about helping people feel seen, supported, and confident that their vision is being handled with real care.",
