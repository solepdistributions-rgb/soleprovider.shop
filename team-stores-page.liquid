<section class="team-stores">
  <div class="page-width">
    <div class="team-stores__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="team-stores__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="team-stores__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="team-stores__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="team-stores__grid">
      {% for block in section.blocks %}
        <div class="team-store-card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link }}" class="team-store-card__media-link">
            <div class="team-store-card__media">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {% else %}
                <div class="team-store-card__placeholder">
                  <span>{{ block.settings.title }}</span>
                </div>
              {% endif %}
            </div>
          </a>

          <div class="team-store-card__content">
            <h3 class="team-store-card__title">{{ block.settings.title }}</h3>

            {% if block.settings.button_label != blank and block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="team-store-card__button">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.bottom_button_label != blank and section.settings.bottom_button_link != blank %}
      <div class="team-stores__footer">
        <a href="{{ section.settings.bottom_button_link }}" class="team-stores__footer-button">
          {{ section.settings.bottom_button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .team-stores {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .team-stores__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 34px;
  }

  .team-stores__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .team-stores__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .team-stores__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .team-stores__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .team-store-card {
    background: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .team-store-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.14);
  }

  .team-store-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #111111;
  }

  .team-store-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .team-store-card:hover .team-store-card__media img {
    transform: scale(1.04);
  }

  .team-store-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #c41230 0%, #111111 100%);
    padding: 20px;
  }

  .team-store-card__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    line-height: 1;
  }

  .team-store-card__content {
    padding: 22px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .team-store-card__title {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .team-store-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 42px;
    padding: 0 16px;
    background: #111111;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    font-size: 1.2rem;
    border: 2px solid #111111;
    transition: all 0.25s ease;
  }

  .team-store-card__button:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  .team-stores__footer {
    text-align: center;
    margin-top: 30px;
  }

  .team-stores__footer-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    background: #c41230;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid #c41230;
    transition: all 0.25s ease;
  }

  .team-stores__footer-button:hover {
    background: #111111;
    border-color: #111111;
    color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .team-stores {
      padding: 64px 0;
    }

    .team-stores__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .team-stores__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Team Stores Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Organization Stores"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Team Stores"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Private team stores make it easy for organizations, schools, and groups to offer custom merchandise through a dedicated shopping experience."
    },
    {
      "type": "text",
      "id": "bottom_button_label",
      "label": "Bottom button label",
      "default": "Start a Team Store"
    },
    {
      "type": "url",
      "id": "bottom_button_link",
      "label": "Bottom button link"
    }
  ],
  "blocks": [
    {
      "type": "store_card",
      "name": "Store Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Store image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Store name",
          "default": "Bryant Running Club"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Store link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "View Store"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Stores Grid",
      "blocks": [
        {
          "type": "store_card",
          "settings": {
            "title": "Bryant Running Club"
          }
        },
        {
          "type": "store_card",
          "settings": {
            "title": "Staff Apparel"
          }
        },
        {
          "type": "store_card",
          "settings": {
            "title": "Youth Baseball"
          }
        }
      ]
    }
  ]
}
{% endschema %}