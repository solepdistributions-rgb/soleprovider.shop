{% comment %}
  Apparel Collection Hero — sections/apparel-collection-hero.liquid
  - Branded black header with breadcrumb
  - Category switcher pill bar
  - Collapsible filter dropdowns (tag-based, native Shopify URL params)
{% endcomment %}

{% liquid
  assign current_handle = collection.handle
  assign current_tags = current_tags | default: collection.current_type
%}

<div class="ac-wrap">

  <!-- ── HEADER ── -->
  <div class="ac-header">
    <div class="page-width">
      <div class="ac-header__inner">
        <div class="ac-header__left">
          <nav class="ac-breadcrumb" aria-label="Breadcrumb">
            <a href="/" class="ac-breadcrumb__link">Home</a>
            <span class="ac-breadcrumb__sep">→</span>
            <a href="/pages/apparel" class="ac-breadcrumb__link">Apparel</a>
            <span class="ac-breadcrumb__sep">→</span>
            <span class="ac-breadcrumb__current">{{ collection.title }}</span>
          </nav>
          <h1 class="ac-header__title">{{ collection.title }}</h1>
        </div>
        <div class="ac-header__right">
          <span class="ac-header__count">{{ collection.products_count }} Style{% if collection.products_count != 1 %}s{% endif %}</span>
          <span class="ac-header__tag">· Add Any Item to Quote</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── CATEGORY SWITCHER ── -->
  <div class="ac-cats">
    <div class="page-width">
      <div class="ac-cats__inner">
        <span class="ac-cats__label">Category</span>
        <div class="ac-cats__pills">
          {% for block in section.blocks %}
            {% if block.type == 'category' %}
              
                href="{{ block.settings.collection_link }}"
                class="ac-cats__pill{% if current_handle == block.settings.collection_handle %} ac-cats__pill--active{% endif %}"
              >
                {{ block.settings.label }}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Filter bar moved to collection-filter-bar.liquid snippet, rendered by main-collection-product-grid {%- endcomment -%}

</div>

<style>
  /* ── HEADER ── */
  .ac-wrap { border-bottom: 1px solid #e0e0e0; }

  .ac-header {
    background: #111111;
    padding: 32px 0 24px;
    border-bottom: 3px solid #c41230;
  }
  .ac-header__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .ac-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .ac-breadcrumb__link {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }
  .ac-breadcrumb__link:hover { color: #c41230; }
  .ac-breadcrumb__sep { color: rgba(255,255,255,0.2); font-size: 1rem; }
  .ac-breadcrumb__current {
    color: rgba(255,255,255,0.75);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ac-header__title {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }
  .ac-header__right {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 4px;
    flex-shrink: 0;
  }
  .ac-header__count {
    background: #c41230;
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
  }
  .ac-header__tag {
    color: rgba(255,255,255,0.45);
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── CATEGORY PILLS ── */
  .ac-cats {
    background: #1a1a1a;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .ac-cats__inner {
    display: flex;
    align-items: center;
    gap: 16px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .ac-cats__inner::-webkit-scrollbar { display: none; }
  .ac-cats__label {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ac-cats__pills {
    display: flex;
    gap: 8px;
    flex-wrap: nowrap;
  }
  .ac-cats__pill {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding: 0 14px;
    border: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    transition: all 0.2s ease;
  }
  .ac-cats__pill:hover {
    border-color: #c41230;
    color: #ffffff;
    background: rgba(196,18,48,0.15);
  }
  .ac-cats__pill--active {
    background: #c41230 !important;
    border-color: #c41230 !important;
    color: #ffffff !important;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 989px) {
    .ac-header__right { display: none; }
  }
</style>

{%- comment -%} Filter JS moved to collection-filter-bar.liquid snippet {%- endcomment -%}

{% schema %}
{
  "name": "Apparel Collection Header",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category Pill",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "T-Shirts" },
        { "type": "url", "id": "collection_link", "label": "Collection link" },
        { "type": "text", "id": "collection_handle", "label": "Collection handle (exact)", "info": "e.g. apparel-tshirts — used to highlight the active pill", "default": "apparel-tshirts" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Apparel Collection Header",
      "blocks": [
        { "type": "category", "settings": { "label": "T-Shirts", "collection_link": "/collections/apparel-tshirts", "collection_handle": "apparel-tshirts" } },
        { "type": "category", "settings": { "label": "Hoodies", "collection_link": "/collections/apparel-hoodies", "collection_handle": "apparel-hoodies" } },
        { "type": "category", "settings": { "label": "Polos", "collection_link": "/collections/apparel-polos", "collection_handle": "apparel-polos" } },
        { "type": "category", "settings": { "label": "Hats", "collection_link": "/collections/apparel-hats", "collection_handle": "apparel-hats" } },
        { "type": "category", "settings": { "label": "Outerwear", "collection_link": "/collections/apparel-outerwear", "collection_handle": "apparel-outerwear" } },
        { "type": "category", "settings": { "label": "Youth", "collection_link": "/collections/apparel-youth", "collection_handle": "apparel-youth" } }
      ]
    }
  ]
}
{% endschema %}