<div class="github-test-hero">
  <div class="github-test-hero__content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </div>
</div>

<style>
  .github-test-hero {
    background-color: #1a1a2e;
    color: #ffffff;
    text-align: center;
    padding: 60px 20px;
  }
  .github-test-hero__content {
    max-width: 800px;
    margin: 0 auto;
  }
  .github-test-hero h1 {
    font-size: 2.5rem;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }
  .github-test-hero p {
    font-size: 1.1rem;
    margin: 0;
    opacity: 0.85;
  }
</style>

{% schema %}
{
  "name": "GitHub Test Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Connected via GitHub"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "This banner was deployed through the Shopify-GitHub integration"
    }
  ],
  "presets": [
    {
      "name": "GitHub Test Hero"
    }
  ]
}
{% endschema %}
