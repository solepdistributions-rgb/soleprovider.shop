<section class="quote-cart-page">
  <div class="page-width">
    <div class="quote-cart-page__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="quote-cart-page__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="quote-cart-page__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="quote-cart-page__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="quote-cart-page__layout">
      <div class="quote-cart-page__items-wrap">
        <div class="quote-cart-page__items-header">
          <h2>Your Selected Items</h2>
        </div>

        <div id="quote-cart-items" class="quote-cart-page__items">
          <div class="quote-cart-page__empty">
            <p class="quote-cart-page__empty-title">Your quote cart is empty.</p>
            <p class="quote-cart-page__empty-text">
              Add products from apparel, promotional products, or other sections to build one organized quote request.
            </p>
          </div>
        </div>
      </div>

      <div class="quote-cart-page__form-wrap">
        <h2 class="quote-cart-page__form-heading">Project Details</h2>

        {% form 'contact', class: 'quote-cart-page__form', id: 'quote-cart-form' %}
          {% if form.posted_successfully? %}
            <div class="quote-cart-page__form-message quote-cart-page__form-message--success quote-cart-page__form-message--success-box" aria-live="polite">
              <strong>Your quote request was submitted successfully.</strong><br>
              Your cart has been cleared. If you submitted files through the artwork upload form below, we will match them using the same Request ID.
              <div id="quote-cart-success-request-id" class="quote-cart-page__success-request-id"></div>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="quote-cart-page__form-message quote-cart-page__form-message--error" aria-live="polite">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <input type="hidden" name="contact[request_type]" value="Quote Cart">
          <input type="hidden" name="contact[source_page]" id="quote-source-page" value="">
          <input type="hidden" name="contact[request_id]" id="quote-request-id" value="">
          <input type="hidden" name="contact[cart_summary]" id="quote-cart-summary" value="">
          <input type="hidden" name="contact[tags]" value="quote-cart,custom-quote">
          <input type="hidden" id="quote-form-success-flag" value="{% if form.posted_successfully? %}true{% else %}false{% endif %}">

          <div class="quote-cart-page__field-group">
            <label for="quote-name">Name</label>
            <input
              id="quote-name"
              name="contact[name]"
              type="text"
              placeholder="Your name"
              value="{% if form.name %}{{ form.name | escape }}{% endif %}"
              required
            >
          </div>

          <div class="quote-cart-page__field-group">
            <label for="quote-company">Company / Organization</label>
            <input
              id="quote-company"
              name="contact[company]"
              type="text"
              placeholder="Business, school, team, or organization"
              value="{% if form.company %}{{ form.company | escape }}{% endif %}"
            >
          </div>

          <div class="quote-cart-page__field-group">
            <label for="quote-email">Email</label>
            <input
              id="quote-email"
              name="contact[email]"
              type="email"
              placeholder="you@example.com"
              autocorrect="off"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email | escape }}{% endif %}"
              required
            >
          </div>

          <div class="quote-cart-page__field-group">
            <label for="quote-phone">Phone</label>
            <input
              id="quote-phone"
              name="contact[phone]"
              type="tel"
              placeholder="Phone number"
              value="{% if form.phone %}{{ form.phone | escape }}{% endif %}"
            >
          </div>

          <div class="quote-cart-page__field-group">
            <label for="quote-date">Needed By</label>
            <input id="quote-date" name="contact[needed_by]" type="date">
          </div>

          <div class="quote-cart-page__field-group">
            <label for="quote-artwork-status">Artwork Status</label>
            <select id="quote-artwork-status" name="contact[artwork_status]">
              <option value="">Select an option</option>
              <option value="ready">Artwork is ready</option>
              <option value="needs_cleanup">Artwork needs cleanup</option>
              <option value="needs_design">I need design help</option>
              <option value="not_sure">Not sure yet</option>
            </select>
          </div>

          <div class="quote-cart-page__field-group quote-cart-page__field-group--full">
            <label for="quote-notes">Project Notes</label>
            <textarea
              id="quote-notes"
              name="quote_notes"
              rows="6"
              placeholder="Tell us about your project, goals, timing, artwork, decoration methods, or anything else we should know."
            ></textarea>
          </div>

          <textarea
            id="quote-body-hidden"
            name="contact[body]"
            style="display: none;"
            aria-hidden="true"
          ></textarea>

          <div class="quote-cart-page__actions">
            <button type="button" class="quote-cart-page__button quote-cart-page__button--secondary" id="clear-quote-cart">
              Clear Quote Cart
            </button>

            <button type="submit" class="quote-cart-page__button quote-cart-page__button--primary">
              Submit Quote Request
            </button>
          </div>

          <div id="quote-cart-form-message" class="quote-cart-page__form-message" aria-live="polite"></div>
        {% endform %}

        <div class="quote-cart-upload">
          <div class="quote-cart-upload__intro">
            <p class="quote-cart-upload__eyebrow">Artwork Upload</p>
            <h3 class="quote-cart-upload__title">Upload Artwork or Project Files</h3>
            <p class="quote-cart-upload__text">
              Upload logos, screenshots, design files, or reference images for this quote.
            </p>
          </div>

          <div class="rq-upload-form" id="qcArtworkUpload">
            <div style="border:2px dashed #ccc;border-radius:8px;padding:2rem;text-align:center"
              ondragover="event.preventDefault(); this.style.borderColor='#c41230'; this.style.background='#fef2f2'"
              ondragleave="this.style.borderColor='#ccc'; this.style.background=''"
              ondrop="event.preventDefault(); this.style.borderColor='#ccc'; this.style.background=''; qcHandleFiles(event.dataTransfer.files)">
              <p style="color:#888;margin:0 0 0.5rem">Drag & drop files here, or</p>
              <label style="display:inline-block;background:#111;color:#fff;padding:0.5rem 1.5rem;border-radius:6px;font-weight:700;font-size:0.9rem;cursor:pointer;text-transform:uppercase">
                Browse Files
                <input type="file" multiple accept=".png,.jpg,.jpeg,.gif,.svg,.ai,.eps,.pdf,.psd,.zip" style="display:none" onchange="qcHandleFiles(this.files)">
              </label>
              <p style="font-size:0.75rem;color:#aaa;margin-top:0.5rem">PNG, JPG, SVG, AI, EPS, PDF, PSD, ZIP — Max 25MB per file</p>
            </div>
            <div id="qcFileList" style="margin-top:0.75rem"></div>
            <div id="qcUploadStatus" style="margin-top:0.75rem;font-size:0.85rem"></div>
          </div>
          <script>
            var qcUploadedFiles = [];
            function qcHandleFiles(files) {
              var list = document.getElementById('qcFileList');
              for (var i = 0; i < files.length; i++) {
                qcUploadedFiles.push(files[i]);
                var div = document.createElement('div');
                div.style.cssText = 'display:flex;justify-content:space-between;padding:0.5rem 0.75rem;background:#f9f9f9;border-radius:4px;margin-bottom:0.25rem;font-size:0.85rem';
                div.innerHTML = '<span>' + files[i].name + '</span><span style="color:#888;font-size:0.75rem">' + Math.round(files[i].size/1024) + 'KB</span>';
                list.appendChild(div);
              }
              var reqField = document.getElementById('quote-request-id');
              var requestId = reqField ? reqField.value : 'QC-' + Date.now();
              var formData = new FormData();
              formData.append('request_id', requestId);
              qcUploadedFiles.forEach(function(f) { formData.append('files', f); });
              var status = document.getElementById('qcUploadStatus');
              status.innerHTML = '<span style="color:#666">Uploading...</span>';
              fetch('https://sp-tools-production.up.railway.app/api/inbox/webhook/upload', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                  status.innerHTML = d.success ? '<span style="color:#16a34a;font-weight:700">✓ ' + d.files.length + ' file(s) uploaded</span>' : '<span style="color:#dc2626">Upload failed</span>';
                  qcUploadedFiles = [];
                }).catch(function() { status.innerHTML = '<span style="color:#dc2626">Upload failed</span>'; });
            }
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-cart-page {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .quote-cart-page__intro {
    text-align: center;
    max-width: 840px;
    margin: 0 auto 36px;
  }

  .quote-cart-page__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .quote-cart-page__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3rem, 5vw, 5.6rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .quote-cart-page__text {
    margin: 0;
    font-size: 1.7rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .quote-cart-page__layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 28px;
    align-items: start;
  }

  .quote-cart-page__items-wrap,
  .quote-cart-page__form-wrap {
    background: #ffffff;
    border-radius: 22px;
    padding: 28px 24px;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.08);
  }

  .quote-cart-page__items-header h2,
  .quote-cart-page__form-heading {
    margin: 0 0 18px;
    font-family: var(--sole-heading-font);
    font-size: 2.4rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .quote-cart-page__items {
    min-height: 260px;
  }

  .quote-cart-page__empty {
    border: 1px dashed rgba(17, 17, 17, 0.18);
    border-radius: 18px;
    padding: 32px 24px;
    text-align: center;
    background: #fafafa;
  }

  .quote-cart-page__empty-title {
    margin: 0 0 8px;
    font-size: 1.9rem;
    font-weight: 800;
    color: #111111;
  }

  .quote-cart-page__empty-text {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .quote-cart-page__line {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 18px 0;
    border-bottom: 1px solid rgba(17,17,17,0.08);
  }

  .quote-cart-page__line-image {
    width: 96px;
    height: 96px;
    border-radius: 12px;
    overflow: hidden;
    background: #f1f1f1;
  }

  .quote-cart-page__line-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .quote-cart-page__line-title {
    margin: 0 0 6px;
    font-size: 1.7rem;
    font-weight: 800;
    color: #111111;
  }

  .quote-cart-page__line-title a {
    color: #111111;
    text-decoration: none;
  }

  .quote-cart-page__line-title a:hover {
    color: #c41230;
  }

  .quote-cart-page__line-meta {
    margin: 0 0 4px;
    font-size: 1.45rem;
    color: #4a4a4a;
    line-height: 1.5;
  }

  .quote-cart-page__size-breakdown {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 8px 0 6px;
  }

  .quote-cart-page__size-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 999px;
    background: #f3f3f3;
    font-size: 1.25rem;
    font-weight: 700;
    color: #111111;
  }

  .quote-cart-page__size-pill strong {
    font-weight: 800;
  }

  .quote-cart-page__line-actions {
    display: grid;
    gap: 10px;
    justify-items: end;
    min-width: 110px;
  }

  .quote-cart-page__qty-controls {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(17,17,17,0.14);
    border-radius: 10px;
    overflow: hidden;
    background: #ffffff;
  }

  .quote-cart-page__qty-btn {
    width: 34px;
    height: 34px;
    border: 0;
    background: #f3f3f3;
    color: #111111;
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
  }

  .quote-cart-page__qty-btn:hover {
    background: #e6e6e6;
  }

  .quote-cart-page__qty-value {
    min-width: 42px;
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: #111111;
    padding: 0 8px;
  }

  .quote-cart-page__line-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 0 12px;
    border-radius: 999px;
    background: #f3f3f3;
    color: #111111;
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .quote-cart-page__remove {
    background: none;
    border: none;
    color: #c41230;
    font-weight: 800;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 1.2rem;
  }

  .quote-cart-page__remove:hover {
    color: #111111;
  }

  .quote-cart-page__form {
    display: grid;
    gap: 16px;
  }

  .quote-cart-page__field-group {
    display: grid;
    gap: 8px;
  }

  .quote-cart-page__field-group--full {
    grid-column: 1 / -1;
  }

  .quote-cart-page__field-group label {
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #111111;
  }

  .quote-cart-page__field-group input,
  .quote-cart-page__field-group textarea,
  .quote-cart-page__field-group select {
    width: 100%;
    border: 1px solid rgba(17, 17, 17, 0.16);
    border-radius: 12px;
    padding: 14px 14px;
    font-size: 1.5rem;
    color: #111111;
    background: #ffffff;
  }

  .quote-cart-page__field-group input:focus,
  .quote-cart-page__field-group textarea:focus,
  .quote-cart-page__field-group select:focus {
    outline: none;
    border-color: #c41230;
    box-shadow: 0 0 0 2px rgba(196, 18, 48, 0.12);
  }

  .quote-cart-upload {
    margin-top: 24px;
    padding: 20px;
    border: 1px solid rgba(196,18,48,0.18);
    background: #fff8f9;
    box-shadow: 0 4px 0 rgba(196,18,48,0.08);
  }

  .quote-cart-upload__eyebrow {
    margin: 0 0 6px;
    color: #c41230;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .quote-cart-upload__title {
    margin: 0 0 8px;
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    line-height: 1;
    text-transform: uppercase;
    font-weight: 900;
    color: #111111;
  }

  .quote-cart-upload__text {
    margin: 0 0 12px;
    font-size: 1.35rem;
    line-height: 1.6;
    color: #555555;
  }

  .quote-cart-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 4px;
  }

  .quote-cart-page__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid transparent;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .quote-cart-page__button--primary {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  .quote-cart-page__button--primary:hover {
    background: #111111;
    border-color: #111111;
    color: #ffffff;
  }

  .quote-cart-page__button--secondary {
    background: transparent;
    color: #111111;
    border-color: #111111;
  }

  .quote-cart-page__button--secondary:hover {
    background: #111111;
    color: #ffffff;
  }

  .quote-cart-page__form-message {
    margin-top: 8px;
    font-size: 1.4rem;
    font-weight: 700;
  }

  .quote-cart-page__form-message--success {
    color: #1a7f37;
  }

  .quote-cart-page__form-message--success-box {
    background: #eef9f0;
    border: 1px solid rgba(26, 127, 55, 0.22);
    border-radius: 14px;
    padding: 16px 18px;
    line-height: 1.7;
  }

  .quote-cart-page__success-request-id {
    margin-top: 10px;
    font-size: 1.3rem;
    font-weight: 800;
    color: #111111;
  }

  .quote-cart-page__form-message--error {
    color: #c41230;
  }

  @media screen and (max-width: 989px) {
    .quote-cart-page {
      padding: 64px 0;
    }

    .quote-cart-page__layout {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .quote-cart-page__line {
      grid-template-columns: 72px 1fr;
    }

    .quote-cart-page__line-actions {
      grid-column: 1 / -1;
      justify-items: start;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const quoteItemsContainer = document.getElementById('quote-cart-items');
    const clearButton = document.getElementById('clear-quote-cart');
    const quoteForm = document.getElementById('quote-cart-form');
    const formMessage = document.getElementById('quote-cart-form-message');
    const requestIdField = document.getElementById('quote-request-id');
    const sourcePageField = document.getElementById('quote-source-page');
    const cartSummaryField = document.getElementById('quote-cart-summary');
    const successFlag = document.getElementById('quote-form-success-flag');
    const successRequestIdBox = document.getElementById('quote-cart-success-request-id');

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getQuoteItems() {
      try {
        return JSON.parse(localStorage.getItem('soleProviderQuoteCart') || '[]');
      } catch (error) {
        return [];
      }
    }

    function saveQuoteItems(items) {
      localStorage.setItem('soleProviderQuoteCart', JSON.stringify(items));
      document.dispatchEvent(new CustomEvent('quoteCartUpdated'));
    }

    function setFormMessage(message, type) {
      if (!formMessage) return;

      formMessage.textContent = message;
      formMessage.classList.remove(
        'quote-cart-page__form-message--success',
        'quote-cart-page__form-message--error'
      );

      if (type === 'success') {
        formMessage.classList.add('quote-cart-page__form-message--success');
      }

      if (type === 'error') {
        formMessage.classList.add('quote-cart-page__form-message--error');
      }
    }

    function getNumericValue(value, fallback) {
      var parsed = parseInt(value, 10);
      return isNaN(parsed) ? fallback : parsed;
    }

    function isSizeBreakdownItem(item) {
      return !!(
        item &&
        item.sizeMode === 'breakdown' &&
        item.sizeBreakdown &&
        typeof item.sizeBreakdown === 'object'
      );
    }

    function isUnknownSizeItem(item) {
      return !!(
        item &&
        item.sizeMode === 'unknown' &&
        item.estimatedQtyRange
      );
    }

    function isSimpleQuantityItem(item) {
      return !isSizeBreakdownItem(item) && !isUnknownSizeItem(item);
    }

    function getSizeSortRank(size) {
      var normalized = String(size || '').trim().toUpperCase();

      var order = {
        'YXS': 1,
        'YS': 2,
        'YM': 3,
        'YL': 4,
        'YXL': 5,
        'XS': 10,
        'S': 20,
        'M': 30,
        'L': 40,
        'XL': 50,
        '2XL': 60,
        'XXL': 60,
        '3XL': 70,
        'XXXL': 70,
        '4XL': 80,
        '5XL': 90,
        '6XL': 100
      };

      if (order[normalized] != null) {
        return order[normalized];
      }

      return 999;
    }

    function compareSizes(a, b) {
      var sizeA = String(a || '');
      var sizeB = String(b || '');

      var rankA = getSizeSortRank(sizeA);
      var rankB = getSizeSortRank(sizeB);

      if (rankA !== rankB) {
        return rankA - rankB;
      }

      return sizeA.localeCompare(sizeB, undefined, { numeric: true, sensitivity: 'base' });
    }

    function getSizeBreakdownEntries(item) {
      if (!item || !item.sizeBreakdown || typeof item.sizeBreakdown !== 'object') {
        return [];
      }

      return Object.keys(item.sizeBreakdown)
        .map(function(size) {
          return [size, getNumericValue(item.sizeBreakdown[size], 0)];
        })
        .filter(function(entry) {
          return entry[1] > 0;
        })
        .sort(function(a, b) {
          return compareSizes(a[0], b[0]);
        });
    }

    function getSizeBreakdownTotal(item) {
      if (item && item.totalQuantity) {
        return getNumericValue(item.totalQuantity, 0);
      }

      return getSizeBreakdownEntries(item).reduce(function(total, entry) {
        return total + entry[1];
      }, 0);
    }

    function buildSizeBreakdownHtml(item) {
      var entries = getSizeBreakdownEntries(item);

      if (!entries.length) return '';

      return `
        <div class="quote-cart-page__size-breakdown">
          ${entries.map(function(entry) {
            return `
              <span class="quote-cart-page__size-pill">
                <strong>${escapeHtml(entry[0])}</strong>
                <span>${escapeHtml(entry[1])}</span>
              </span>
            `;
          }).join('')}
        </div>
      `;
    }

    function buildItemDetailsHtml(item) {
      var parts = [];
      var metaLabel = (isSizeBreakdownItem(item) || isUnknownSizeItem(item)) ? 'Selection' : 'Variant';

      if (item.variant) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>${metaLabel}:</strong> ${escapeHtml(item.variant)}</p>`);
      }

      if (isSizeBreakdownItem(item)) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Total Qty:</strong> ${escapeHtml(getSizeBreakdownTotal(item))}</p>`);
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Sizes:</strong></p>`);
        parts.push(buildSizeBreakdownHtml(item));
      }

      if (isUnknownSizeItem(item)) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Size Breakdown:</strong> I don’t know my size breakdown yet</p>`);
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Estimated Qty Range:</strong> ${escapeHtml(item.estimatedQtyRange)}</p>`);
      }

      if (item.decoration) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Decoration:</strong> ${escapeHtml(item.decoration)}</p>`);
      }

      if (item.artworkStatus) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Artwork:</strong> ${escapeHtml(item.artworkStatus)}</p>`);
      }

      if (item.sku && isSimpleQuantityItem(item)) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>SKU:</strong> ${escapeHtml(item.sku)}</p>`);
      }

      if (item.notes) {
        parts.push(`<p class="quote-cart-page__line-meta"><strong>Notes:</strong> ${escapeHtml(item.notes)}</p>`);
      }

      return parts.join('');
    }

    function buildItemActionsHtml(item, index) {
      if (isSimpleQuantityItem(item)) {
        return `
          <div class="quote-cart-page__qty-controls">
            <button type="button" class="quote-cart-page__qty-btn" data-qty-minus="${index}" aria-label="Decrease quantity">−</button>
            <span class="quote-cart-page__qty-value">${escapeHtml(getNumericValue(item.quantity || 1, 1))}</span>
            <button type="button" class="quote-cart-page__qty-btn" data-qty-plus="${index}" aria-label="Increase quantity">+</button>
          </div>

          <button type="button" class="quote-cart-page__remove" data-remove-index="${index}">
            Remove
          </button>
        `;
      }

      if (isSizeBreakdownItem(item)) {
        return `
          <div class="quote-cart-page__line-chip">Total ${escapeHtml(getSizeBreakdownTotal(item))}</div>
          <button type="button" class="quote-cart-page__remove" data-remove-index="${index}">
            Remove
          </button>
        `;
      }

      return `
        <div class="quote-cart-page__line-chip">${escapeHtml(item.estimatedQtyRange || 'Range')}</div>
        <button type="button" class="quote-cart-page__remove" data-remove-index="${index}">
          Remove
        </button>
      `;
    }

    function updateItemQuantity(index, delta) {
      const items = getQuoteItems();
      if (!items[index]) return;
      if (!isSimpleQuantityItem(items[index])) return;

      const currentQty = getNumericValue(items[index].quantity || 1, 1);
      const nextQty = currentQty + delta;

      if (nextQty <= 0) {
        items.splice(index, 1);
      } else {
        items[index].quantity = nextQty;
      }

      saveQuoteItems(items);
      renderQuoteCart();
      syncFormState();
      syncNerdyFields();
    }

    function removeItem(index) {
      const items = getQuoteItems();
      if (!items[index]) return;

      items.splice(index, 1);
      saveQuoteItems(items);
      renderQuoteCart();
      syncFormState();
      syncNerdyFields();
    }

    function renderQuoteCart() {
      const storedQuoteItems = getQuoteItems();

      if (!quoteItemsContainer) return;

      if (!storedQuoteItems.length) {
        quoteItemsContainer.innerHTML = `
          <div class="quote-cart-page__empty">
            <p class="quote-cart-page__empty-title">Your quote cart is empty.</p>
            <p class="quote-cart-page__empty-text">
              Add products from apparel, promotional products, or other sections to build one organized quote request.
            </p>
          </div>
        `;
        return;
      }

      quoteItemsContainer.innerHTML = storedQuoteItems.map(function(item, index) {
        var imageHtml = item.image
          ? `<img src="${escapeHtml(item.image)}" alt="${escapeHtml(item.title || 'Product')}">`
          : '';

        var titleHtml = item.url
          ? `<a href="${escapeHtml(item.url)}">${escapeHtml(item.title || 'Product')}</a>`
          : escapeHtml(item.title || 'Product');

        return `
          <div class="quote-cart-page__line" data-index="${index}">
            <div class="quote-cart-page__line-image">
              ${imageHtml}
            </div>

            <div class="quote-cart-page__line-details">
              <p class="quote-cart-page__line-title">${titleHtml}</p>
              ${buildItemDetailsHtml(item)}
            </div>

            <div class="quote-cart-page__line-actions">
              ${buildItemActionsHtml(item, index)}
            </div>
          </div>
        `;
      }).join('');

      quoteItemsContainer.querySelectorAll('[data-remove-index]').forEach(function(button) {
        button.addEventListener('click', function () {
          removeItem(parseInt(this.getAttribute('data-remove-index'), 10));
        });
      });

      quoteItemsContainer.querySelectorAll('[data-qty-minus]').forEach(function(button) {
        button.addEventListener('click', function () {
          updateItemQuantity(parseInt(this.getAttribute('data-qty-minus'), 10), -1);
        });
      });

      quoteItemsContainer.querySelectorAll('[data-qty-plus]').forEach(function(button) {
        button.addEventListener('click', function () {
          updateItemQuantity(parseInt(this.getAttribute('data-qty-plus'), 10), 1);
        });
      });
    }

    function getOrCreateRequestId() {
      var storageKey = 'sole_provider_request_id_' + window.location.pathname;
      var existing = sessionStorage.getItem(storageKey);

      if (existing) return existing;

      var requestId = 'SP-' + Date.now() + '-' + Math.floor(Math.random() * 100000);
      sessionStorage.setItem(storageKey, requestId);
      return requestId;
    }

    function getQuoteCartSummary() {
      const items = getQuoteItems();

      if (!items.length) return 'No items in quote cart';

      return items.map(function(item) {
        var parts = [];
        parts.push(item.title || 'Product');

        if (item.variant) {
          parts.push(((isSizeBreakdownItem(item) || isUnknownSizeItem(item)) ? 'Selection: ' : 'Variant: ') + item.variant);
        }

        if (isSizeBreakdownItem(item)) {
          var entries = getSizeBreakdownEntries(item).map(function(entry) {
            return entry[0] + ' x' + entry[1];
          }).join(', ');

          parts.push('Total Qty: ' + getSizeBreakdownTotal(item));
          parts.push('Sizes: ' + entries);

          if (item.sizeVariantMap && typeof item.sizeVariantMap === 'object') {
            var skuSummary = Object.keys(item.sizeVariantMap)
              .sort(compareSizes)
              .map(function(size) {
                var sizeData = item.sizeVariantMap[size] || {};
                return sizeData.sku ? (size + '=' + sizeData.sku) : '';
              })
              .filter(Boolean)
              .join(', ');

            if (skuSummary) {
              parts.push('SKUs: ' + skuSummary);
            }
          }
        } else if (isUnknownSizeItem(item)) {
          parts.push('Estimated Qty Range: ' + item.estimatedQtyRange);
          parts.push('Size Breakdown: Unknown');
        } else {
          parts.push('Qty: ' + getNumericValue(item.quantity || 1, 1));

          if (item.sku) {
            parts.push('SKU: ' + item.sku);
          }
        }

        if (item.decoration) parts.push('Decoration: ' + item.decoration);
        if (item.artworkStatus) parts.push('Artwork: ' + item.artworkStatus);
        if (item.notes) parts.push('Item Notes: ' + item.notes);

        return parts.join(' | ');
      }).join(' || ');
    }

    function syncFormState() {
      var requestId = getOrCreateRequestId();
      var sourcePage = window.location.pathname;
      var cartSummary = getQuoteCartSummary();
      var notesField = document.getElementById('quote-notes');
      var hiddenBodyField = document.getElementById('quote-body-hidden');
      var currentNotes = notesField ? notesField.value.trim() : '';
      var artworkStatus = document.getElementById('quote-artwork-status') ? document.getElementById('quote-artwork-status').value : '';
      var neededBy = document.getElementById('quote-date') ? document.getElementById('quote-date').value : '';
      var company = document.getElementById('quote-company') ? document.getElementById('quote-company').value.trim() : '';
      var phone = document.getElementById('quote-phone') ? document.getElementById('quote-phone').value.trim() : '';

      if (requestIdField) {
        requestIdField.value = requestId;
      }

      if (sourcePageField) {
        sourcePageField.value = sourcePage;
      }

      if (cartSummaryField) {
        cartSummaryField.value = cartSummary;
      }

      if (hiddenBodyField) {
        hiddenBodyField.value = [
          currentNotes ? 'Project Notes:\n' + currentNotes : 'Project Notes:\nNone provided',
          '',
          'Request ID: ' + requestId,
          'Source Page: ' + sourcePage,
          company ? 'Company / Organization: ' + company : '',
          phone ? 'Phone: ' + phone : '',
          neededBy ? 'Needed By: ' + neededBy : '',
          artworkStatus ? 'Artwork Status: ' + artworkStatus : '',
          '',
          'Quote Cart Summary:',
          cartSummary
        ].filter(Boolean).join('\n');
      }
    }

    function setNerdyField(placeholder, value) {
      var field = document.querySelector('input[placeholder="' + placeholder + '"]');
      if (!field) return;

      field.value = value || '';
      field.readOnly = true;
      field.dispatchEvent(new Event('input', { bubbles: true }));
      field.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function hideNerdyField(placeholder) {
      var field = document.querySelector('input[placeholder="' + placeholder + '"]');
      if (!field) return;

      var wrapper = field.closest('.nf-col-12');
      if (wrapper) {
        wrapper.style.display = 'none';
      }
    }

    function syncNerdyFields() {
      var requestId = getOrCreateRequestId();
      var sourcePage = window.location.pathname;
      var customerName = document.getElementById('quote-name') ? document.getElementById('quote-name').value : '';
      var customerEmail = document.getElementById('quote-email') ? document.getElementById('quote-email').value : '';
      var projectType = 'Quote Cart';
      var cartSummary = getQuoteCartSummary();

      setNerdyField('Request ID', requestId);
      setNerdyField('Source Page', sourcePage);
      setNerdyField('Customer Name', customerName);
      setNerdyField('Project Type', projectType);
      setNerdyField('Your email', customerEmail);
      setNerdyField('Cart Summary', cartSummary);

      hideNerdyField('Request ID');
      hideNerdyField('Source Page');
      hideNerdyField('Customer Name');
      hideNerdyField('Project Type');
      hideNerdyField('Your email');
      hideNerdyField('Cart Summary');

      var emailWrapper = document.getElementById('nf-container-email');
      if (emailWrapper) {
        emailWrapper.style.display = 'none';
      }
    }

    function handleSuccessfulSubmission() {
      if (!successFlag || successFlag.value !== 'true') return;

      var requestId = getOrCreateRequestId();

      localStorage.removeItem('soleProviderQuoteCart');

      if (successRequestIdBox) {
        successRequestIdBox.textContent = 'Request ID: ' + requestId;
      }

      renderQuoteCart();
      setFormMessage('', '');
    }

    if (clearButton) {
      clearButton.addEventListener('click', function () {
        localStorage.removeItem('soleProviderQuoteCart');
        renderQuoteCart();
        syncFormState();
        syncNerdyFields();
        setFormMessage('Quote cart cleared.', 'success');
      });
    }

    if (quoteForm) {
      quoteForm.addEventListener('submit', function (event) {
        const quoteItems = getQuoteItems();

        if (!quoteItems.length) {
          event.preventDefault();
          setFormMessage('Please add at least one item to your quote cart before submitting.', 'error');
          return;
        }

        const name = document.getElementById('quote-name')?.value.trim() || '';
        const email = document.getElementById('quote-email')?.value.trim() || '';

        if (!name || !email) {
          event.preventDefault();
          setFormMessage('Please enter your name and email before submitting.', 'error');
          return;
        }

        syncFormState();
        syncNerdyFields();
        setFormMessage('', '');

        // Mirror to SP Tools inbox
        try {
          var formData = new FormData(quoteForm);
          var webhookData = {};
          formData.forEach(function(value, key) {
            webhookData[key.replace('contact[', '').replace(']', '')] = value;
          });
          // Add individual item details with SKUs
          var items = getQuoteItems();
          var itemSummary = items.map(function(item, idx) {
            var parts = ['Item ' + (idx + 1) + ': ' + (item.title || 'Unknown')];
            if (item.sku) parts.push('SKU: ' + item.sku);
            if (item.color) parts.push('Color: ' + item.color);
            if (item.quantity) parts.push('Qty: ' + item.quantity);
            if (item.decoration) parts.push('Deco: ' + item.decoration);
            if (item.url) parts.push('URL: ' + item.url);
            return parts.join(' | ');
          }).join('\n');
          webhookData.details = (webhookData.body || webhookData.details || '') + '\n\n--- ITEMS ---\n' + itemSummary;
          webhookData.quantity = items.length + ' items';
          if (items[0]) {
            webhookData.product_title = items.map(function(i) { return i.title; }).join(', ');
            webhookData.product_sku = items.map(function(i) { return i.sku || ''; }).filter(Boolean).join(', ');
            webhookData.product_url = items[0].url || '';
            webhookData.product_image = items[0].imageUrl || '';
          }
          navigator.sendBeacon(
            'https://sp-tools-production.up.railway.app/api/inbox/webhook',
            new Blob([JSON.stringify(webhookData)], { type: 'application/json' })
          );
        } catch(e) {}
      });
    }

    var nameField = document.getElementById('quote-name');
    var emailField = document.getElementById('quote-email');
    var notesField = document.getElementById('quote-notes');
    var artworkField = document.getElementById('quote-artwork-status');
    var companyField = document.getElementById('quote-company');
    var phoneField = document.getElementById('quote-phone');
    var dateField = document.getElementById('quote-date');

    [nameField, emailField, companyField, phoneField, dateField].forEach(function(field) {
      if (!field) return;

      field.addEventListener('input', function () {
        syncFormState();
        syncNerdyFields();
      });
    });

    if (notesField) {
      notesField.addEventListener('input', function () {
        syncFormState();
        syncNerdyFields();
      });
    }

    if (artworkField) {
      artworkField.addEventListener('change', function () {
        syncFormState();
        syncNerdyFields();
      });
    }

    document.addEventListener('quoteCartUpdated', function() {
      renderQuoteCart();
      syncFormState();
      syncNerdyFields();
    });

    handleSuccessfulSubmission();
    renderQuoteCart();
    syncFormState();

    var syncAttempts = 0;
    var syncInterval = setInterval(function () {
      syncFormState();
      syncNerdyFields();
      syncAttempts += 1;

      if (syncAttempts >= 12) {
        clearInterval(syncInterval);
      }
    }, 500);
  });
</script>

