{
  "name": "Quote Cart Page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Grouped Request"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Quote Cart"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Review your selected items, add project details, and submit one organized quote request."
    }
  ],
  "presets": [
    {
      "name": "Quote Cart Page"
    }
  ]
}
{% endschema %}