<section class="promo-sourcing-cta">
  <div class="page-width">
    <div class="promo-sourcing-cta__card">
      {% if section.settings.eyebrow != blank %}
        <p class="promo-sourcing-cta__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="promo-sourcing-cta__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="promo-sourcing-cta__text">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="promo-sourcing-cta__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .promo-sourcing-cta {
    padding: 64px 0;
    background: #f5f5f5;
  }

  .promo-sourcing-cta__card {
    max-width: 980px;
    margin: 0 auto;
    padding: 42px 36px;
    text-align: center;
    background: linear-gradient(135deg, #111111 0%, #1a1a1a 68%, #c41230 155%);
    border-radius: 22px;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
  }

  .promo-sourcing-cta__eyebrow {
    margin: 0 0 10px;
    color: rgba(255,255,255,0.86);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .promo-sourcing-cta__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .promo-sourcing-cta__text {
    margin: 0 auto 22px;
    max-width: 64rem;
    font-size: 1.65rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.9);
  }

  .promo-sourcing-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 20px;
    background: #ffffff;
    color: #111111;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid #ffffff;
    transition: all 0.25s ease;
  }

  .promo-sourcing-cta__button:hover {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  @media screen and (max-width: 989px) {
    .promo-sourcing-cta {
      padding: 52px 0;
    }

    .promo-sourcing-cta__card {
      padding: 34px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Sourcing CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Need Something Specific?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Don’t See What You Need?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "If you don’t see the exact product you’re looking for, send us a request and we’ll help source the right option for your project."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Request a Product"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Promo Sourcing CTA"
    }
  ]
}
{% endschema %}