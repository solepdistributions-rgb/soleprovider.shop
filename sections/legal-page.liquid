{% comment %}
  Phase A — Legal & FAQ page section
  Renders the appropriate policy/FAQ content based on the page handle.
  Used by templates/page.legal.json (assigned to Pages: terms-of-service,
  refund-policy, shipping-policy, privacy-policy, faq).
{% endcomment %}

{{ 'section-legal-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow legal-page section-{{ section.id }}-padding">
  <article class="legal-page__content rte">
    {%- case page.handle -%}
      {%- when 'terms-of-service' -%}
        {%- render 'legal-terms-of-service' -%}
      {%- when 'refund-policy' -%}
        {%- render 'legal-refund-policy' -%}
      {%- when 'shipping-policy' -%}
        {%- render 'legal-shipping-policy' -%}
      {%- when 'privacy-policy' -%}
        {%- render 'legal-privacy-policy' -%}
      {%- when 'faq' -%}
        {%- render 'legal-faq' -%}
      {%- else -%}
        {%- comment -%}
          Fallback: render whatever the admin page body contains, so this
          template is safe to assign to any future legal page handle.
        {%- endcomment -%}
        <h1>{{ page.title | escape }}</h1>
        {{ page.content }}
    {%- endcase -%}
  </article>
</div>

{% schema %}
{
  "name": "Legal page content",
  "tag": "section",
  "class": "section section--legal-page",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Legal page content"
    }
  ]
}
{% endschema %}
