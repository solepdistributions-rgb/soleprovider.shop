<section class="ap-caps">
  <div class="page-width">
    <div class="ap-caps__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="ap-caps__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ap-caps__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="ap-caps__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>
    <div class="ap-caps__grid">
      {% for block in section.blocks %}
        <div class="ap-caps__card" {{ block.shopify_attributes }}>
          <div class="ap-caps__icon-wrap">
            <span class="ap-caps__icon">{{ block.settings.icon_text }}</span>
          </div>
          <h3 class="ap-caps__title">{{ block.settings.title }}</h3>
          {% if block.settings.text != blank %}
            <p class="ap-caps__body">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ap-caps { padding: 84px 0; background: #ffffff; }
  .ap-caps__intro { text-align: center; max-width: 780px; margin: 0 auto 48px; }
  .ap-caps__eyebrow { margin: 0 0 10px; color: #c41230; font-size: 1.2rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; }
  .ap-caps__heading { margin: 0 0 14px; font-family: var(--sole-heading-font); font-size: clamp(2.8rem, 4vw, 4.8rem); line-height: 0.95; font-weight: 900; text-transform: uppercase; color: #111111; }
  .ap-caps__text { margin: 0; font-size: 1.65rem; line-height: 1.7; color: #4a4a4a; }

  .ap-caps__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 24px; }

  .ap-caps__card { padding: 32px 28px 34px; background: #ffffff; border: 1px solid #d8d8d8; border-bottom: 4px solid #d8d8d8; border-radius: 4px; position: relative; overflow: hidden; box-shadow: 0 4px 0 #c8c8c8, 0 6px 16px rgba(0,0,0,0.07); transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease; }
  .ap-caps__card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #c41230; transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .ap-caps__card:hover { transform: translateY(-6px); box-shadow: 0 10px 0 #b0b0b0, 0 16px 32px rgba(0,0,0,0.13); border-color: #c41230; border-bottom-color: #9a0e24; }
  .ap-caps__card:hover::before { transform: scaleX(1); }

  .ap-caps__icon-wrap { width: 52px; height: 52px; background: #111111; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.25); transition: background 0.28s ease, box-shadow 0.28s ease; }
  .ap-caps__card:hover .ap-caps__icon-wrap { background: #c41230; box-shadow: 0 6px 14px rgba(196,18,48,0.35); }
  .ap-caps__icon { font-family: var(--sole-heading-font); font-size: 1.4rem; font-weight: 900; color: #ffffff; text-transform: uppercase; }
  .ap-caps__title { margin: 0 0 12px; font-family: var(--sole-heading-font); font-size: 2rem; line-height: 1; font-weight: 900; text-transform: uppercase; color: #111111; }
  .ap-caps__body { margin: 0; font-size: 1.5rem; line-height: 1.7; color: #555555; }

  @media screen and (max-width: 989px) {
    .ap-caps { padding: 64px 0; }
    .ap-caps__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media screen and (max-width: 749px) {
    .ap-caps__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Apparel Capabilities",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What We Do" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Full-Service Apparel Capabilities" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Whether you need 12 pieces or 1,200, we have the decoration methods and production relationships to make it happen." }
  ],
  "blocks": [
    {
      "type": "capability",
      "name": "Capability Card",
      "settings": [
        { "type": "text", "id": "icon_text", "label": "Icon (2-3 letters)", "default": "SP" },
        { "type": "text", "id": "title", "label": "Title", "default": "Screen Printing" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Vibrant, durable prints for high-volume runs." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Apparel Capabilities",
      "blocks": [
        { "type": "capability", "settings": { "icon_text": "SP", "title": "Screen Printing", "text": "Vibrant, durable prints ideal for high-volume runs, bold graphics, and team apparel." } },
        { "type": "capability", "settings": { "icon_text": "EM", "title": "Embroidery", "text": "Premium stitched logos that hold up wash after wash. Perfect for polos, hats, and corporate wear." } },
        { "type": "capability", "settings": { "icon_text": "DTF", "title": "DTF Transfers", "text": "Full-color, photo-quality prints on virtually any fabric with no color count limits." } },
        { "type": "capability", "settings": { "icon_text": "HT", "title": "Heat Transfer", "text": "Flexible decoration for short runs, small orders, and specialty materials." } },
        { "type": "capability", "settings": { "icon_text": "DG", "title": "Dye Sublimation", "text": "All-over prints and custom patterns for performance wear and specialty apparel." } },
        { "type": "capability", "settings": { "icon_text": "PK", "title": "Pack & Fulfill", "text": "We sort, bag, tag, and ship individual orders for team stores and group orders." } }
      ]
    }
  ]
}
{% endschema %}