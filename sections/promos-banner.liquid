{%- liquid
  assign api_url = section.settings.api_url | default: 'https://sp-tools-production.up.railway.app'
-%}

<section class="promos-banner" id="promosBanner-{{ section.id }}" data-api="{{ api_url }}">
  <div class="promos-banner__viewport">
    <div class="promos-banner__track" id="promosTrack-{{ section.id }}">
      <!-- Populated by JS -->
    </div>
  </div>

  <button type="button" class="promos-banner__arrow promos-banner__arrow--prev" data-dir="-1" aria-label="Previous promo">&lsaquo;</button>
  <button type="button" class="promos-banner__arrow promos-banner__arrow--next" data-dir="1" aria-label="Next promo">&rsaquo;</button>
</section>

<style>
  .promos-banner {
    background: var(--sole-black, #111);
    position: relative;
    display: none;
    overflow: hidden;
  }
  .promos-banner.has-promos { display: block; }

  .promos-banner__viewport {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 52px;
    overflow: hidden;
  }
  .promos-banner__track {
    display: flex;
    transition: transform 0.5s ease;
    will-change: transform;
  }
  .promo-slide {
    flex: 0 0 100%;
    max-width: 100%;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    min-height: 56px;
    box-sizing: border-box;
  }
  .promo-slide__text {
    flex: 1 1 auto;
    min-width: 0;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .promo-slide__title {
    font-family: var(--sole-heading-font);
    font-size: clamp(0.95rem, 1.5vw, 1.2rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .promo-slide__desc {
    font-family: var(--sole-body-font);
    font-size: 0.78rem;
    color: #b8b8b8;
    margin: 0;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .promo-slide__right {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .promo-slide__code {
    display: inline-block;
    font-family: var(--sole-heading-font);
    font-size: clamp(0.85rem, 1.3vw, 1rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: var(--sole-red, #c41230);
    padding: 9px 20px;
    border-radius: 6px;
    text-decoration: none;
    line-height: 1;
    transition: all 0.15s ease;
    box-shadow: 0 2px 8px rgba(196,18,48,0.35);
    white-space: nowrap;
  }
  .promo-slide__code:hover {
    background: #fff;
    color: var(--sole-red, #c41230);
    transform: translateY(-1px);
  }
  .promo-slide__terms-link {
    font-family: var(--sole-body-font);
    font-size: 0.72rem;
    color: rgba(255,255,255,0.55);
    text-decoration: underline;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .promo-slide__terms-link:hover { color: #fff; }

  /* ===== ARROWS ===== */
  .promos-banner__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    font-family: var(--sole-heading-font);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
    z-index: 2;
    padding: 0;
  }
  .promos-banner.has-multiple .promos-banner__arrow { display: flex; }
  .promos-banner__arrow:hover {
    background: var(--sole-red, #c41230);
    border-color: var(--sole-red, #c41230);
  }
  .promos-banner__arrow--prev { left: 12px; }
  .promos-banner__arrow--next { right: 12px; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 760px) {
    .promos-banner__viewport { padding: 0 42px; }
    .promo-slide {
      flex-direction: column;
      gap: 8px;
      padding: 10px 12px;
      text-align: center;
      min-height: 0;
    }
    .promo-slide__text { text-align: center; align-items: center; }
    .promo-slide__title { white-space: normal; font-size: 0.95rem; }
    .promo-slide__desc { white-space: normal; font-size: 0.75rem; line-height: 1.3; }
    .promo-slide__right { gap: 10px; }
    .promo-slide__code { padding: 8px 16px; font-size: 0.82rem; }
    .promo-slide__terms-link { font-size: 0.68rem; }
    .promos-banner__arrow { width: 26px; height: 26px; font-size: 0.95rem; }
    .promos-banner__arrow--prev { left: 4px; }
    .promos-banner__arrow--next { right: 4px; }
  }
</style>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var root = document.getElementById('promosBanner-' + sectionId);
  if (!root) return;
  var track = document.getElementById('promosTrack-' + sectionId);
  var apiBase = root.getAttribute('data-api');

  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
    });
  }

  // Always-first slide: referral program
  var REFERRAL_SLIDE = {
    code: 'REFERRAL',
    title: 'Refer & Earn Store Credit',
    description: 'Clients earn 4%, non-clients earn 2%. Your referral gets 5% off their first order.',
    is_referral: true,
  };

  // Build a compact one-line summary for tiered promos
  function summarizeTiers(p) {
    if (!p.discount_config) return p.description || '';
    var tiers = String(p.discount_config).split('\n').map(function(l) {
      return l.trim();
    }).filter(Boolean).map(function(l) {
      var parts = l.split(':').map(function(s) { return s.trim(); });
      if (!parts[0] || !parts[1]) return null;
      if (p.discount_type === 'art_discount') {
        return parts[0] + '+ → $' + parts[1] + ' off';
      }
      return parts[0] + '+ → ' + parts[1] + ' free';
    }).filter(Boolean);
    if (!tiers.length) return p.description || '';
    return tiers.join('  ·  ');
  }

  function render(promos) {
    var all = [REFERRAL_SLIDE].concat(promos || []);
    root.classList.add('has-promos');
    if (all.length > 1) root.classList.add('has-multiple');

    track.innerHTML = all.map(function(p) {
      var quoteHref = '/pages/request-quote?promo=' + encodeURIComponent(p.code);
      var termsHref = p.is_referral
        ? '/pages/referral-terms'
        : '/pages/deal-terms#' + encodeURIComponent(p.code);
      var desc = p.is_referral ? p.description : summarizeTiers(p);
      return ''
        + '<div class="promo-slide">'
        +   '<div class="promo-slide__text">'
        +     '<h3 class="promo-slide__title">' + esc(p.title || p.code) + '</h3>'
        +     (desc ? '<p class="promo-slide__desc">' + esc(desc) + '</p>' : '')
        +   '</div>'
        +   '<div class="promo-slide__right">'
        +     '<a class="promo-slide__code" href="' + quoteHref + '">' + esc(p.code) + '</a>'
        +     '<a class="promo-slide__terms-link" href="' + termsHref + '">Terms</a>'
        +   '</div>'
        + '</div>';
    }).join('');

    var idx = 0;
    var total = all.length;

    function go(next) {
      idx = ((next % total) + total) % total;
      track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    }

    root.querySelectorAll('.promos-banner__arrow').forEach(function(btn) {
      btn.addEventListener('click', function() {
        go(idx + parseInt(btn.getAttribute('data-dir'), 10));
        resetTimer();
      });
    });

    var timer = null;
    function startTimer() {
      if (total <= 1) return;
      timer = setInterval(function() { go(idx + 1); }, 6000);
    }
    function resetTimer() {
      if (timer) clearInterval(timer);
      startTimer();
    }
    startTimer();
  }

  fetch(apiBase + '/api/public/promos', { credentials: 'omit' })
    .then(function(r) { return r.json(); })
    .then(function(d) { render((d && d.promos) || []); })
    .catch(function() { render([]); });
})();
</script>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "SP Tools API URL",
      "default": "https://sp-tools-production.up.railway.app"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
