<section class="meet-owner">
  <div class="page-width">
    <div class="meet-owner__grid">
      <div class="meet-owner__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1400 }}"
            alt="{{ section.settings.name | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% else %}
          <div class="meet-owner__placeholder">
            <span>{{ section.settings.name }}</span>
          </div>
        {% endif %}
      </div>

      <div class="meet-owner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="meet-owner__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="meet-owner__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.name != blank %}
          <h3 class="meet-owner__name">{{ section.settings.name }}</h3>
        {% endif %}

        {% if section.settings.title != blank %}
          <p class="meet-owner__title">{{ section.settings.title }}</p>
        {% endif %}

        {% if section.settings.paragraph_1 != blank %}
          <p class="meet-owner__text">{{ section.settings.paragraph_1 }}</p>
        {% endif %}

        {% if section.settings.paragraph_2 != blank %}
          <p class="meet-owner__text">{{ section.settings.paragraph_2 }}</p>
        {% endif %}

        {% if section.settings.paragraph_3 != blank %}
          <p class="meet-owner__text">{{ section.settings.paragraph_3 }}</p>
        {% endif %}

        <div class="meet-owner__buttons">
          {% if section.settings.linkedin_label != blank and section.settings.linkedin_link != blank %}
            <a href="{{ section.settings.linkedin_link }}" class="meet-owner__button meet-owner__button--primary">
              {{ section.settings.linkedin_label }}
            </a>
          {% endif %}

          {% if section.settings.contact_label != blank and section.settings.contact_link != blank %}
            <a href="{{ section.settings.contact_link }}" class="meet-owner__button meet-owner__button--secondary">
              {{ section.settings.contact_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .meet-owner {
    padding: 84px 0;
    background: #ffffff;
  }

  .meet-owner__grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 40px;
    align-items: center;
  }

  .meet-owner__media img,
  .meet-owner__placeholder {
    display: block;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
  }

  .meet-owner__media img {
    height: auto;
    object-fit: cover;
  }

  .meet-owner__placeholder {
    min-height: 420px;
    background: linear-gradient(135deg, #111111 0%, #c41230 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .meet-owner__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 3rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    line-height: 1;
  }

  .meet-owner__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .meet-owner__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .meet-owner__name {
    margin: 0 0 6px;
    font-size: 2.2rem;
    font-weight: 800;
    color: #111111;
  }

  .meet-owner__title {
    margin: 0 0 18px;
    font-size: 1.55rem;
    font-weight: 700;
    color: #c41230;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meet-owner__text {
    margin: 0 0 16px;
    font-size: 1.65rem;
    line-height: 1.75;
    color: #444444;
  }

  .meet-owner__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 18px;
  }

  .meet-owner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid transparent;
    transition: all 0.25s ease;
  }

  .meet-owner__button--primary {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }

  .meet-owner__button--primary:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  .meet-owner__button--secondary {
    background: transparent;
    color: #111111;
    border-color: #111111;
  }

  .meet-owner__button--secondary:hover {
    background: #111111;
    color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .meet-owner {
      padding: 64px 0;
    }

    .meet-owner__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Meet the Owner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Founder Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the Owner"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Owner image"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Sean D. Nelson"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Founder, The Sole Provider"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "The Sole Provider is built on creativity, resilience, and a genuine commitment to people. Founded by Sean D. Nelson, the brand grew from a passion for products and design into a full-service promotional branding agency focused on making custom merchandise and branded materials easier, more personal, and more effective for every client."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Part of that journey has been shaped by personal challenges, including brain surgery, which helped deepen Sean’s perspective on resilience, purpose, and the importance of building something meaningful. That perspective carries into the business today through a focus on relationships, attention to detail, and making every client feel valued."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "Whether working with a small team, a growing brand, or a larger organization, the goal is always the same: to create work that feels intentional, high quality, and built with care."
    },
    {
      "type": "text",
      "id": "linkedin_label",
      "label": "LinkedIn button label",
      "default": "Connect on LinkedIn"
    },
    {
      "type": "url",
      "id": "linkedin_link",
      "label": "LinkedIn link"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Me"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact button link"
    }
  ],
  "presets": [
    {
      "name": "Meet the Owner"
    }
  ]
}
{% endschema %}