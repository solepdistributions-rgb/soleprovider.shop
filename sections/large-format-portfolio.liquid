<section class="lf-portfolio">
  <div class="page-width">
    {% if section.settings.eyebrow != blank %}
      <p class="lf-portfolio__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="lf-portfolio__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="lf-portfolio__text">{{ section.settings.text }}</p>
    {% endif %}

    <div class="lf-portfolio__grid">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <div class="lf-portfolio__item" {{ block.shopify_attributes }}>
            <div class="lf-portfolio__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.caption | default: 'Project' | escape }}"
                loading="lazy"
                class="lf-portfolio__img"
              >
            </div>
            {% if block.settings.caption != blank or block.settings.client != blank %}
              <div class="lf-portfolio__info">
                {% if block.settings.caption != blank %}
                  <h3 class="lf-portfolio__caption">{{ block.settings.caption }}</h3>
                {% endif %}
                {% if block.settings.client != blank %}
                  <p class="lf-portfolio__client">{{ block.settings.client }}</p>
                {% endif %}
                {% if block.settings.service_type != blank %}
                  <span class="lf-portfolio__tag">{{ block.settings.service_type }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="lf-portfolio__cta">
        <a href="{{ section.settings.cta_link | default: '/pages/request-quote' }}" class="lf-portfolio__button">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}
  </div>

  <!-- Lightbox -->
  <div class="lf-portfolio__lightbox" id="lf-lightbox" onclick="this.classList.remove('is-active')">
    <button class="lf-portfolio__lightbox-close" onclick="document.getElementById('lf-lightbox').classList.remove('is-active')">&times;</button>
    <img class="lf-portfolio__lightbox-img" id="lf-lightbox-img" src="" alt="">
  </div>
</section>

<script>
  document.querySelectorAll('.lf-portfolio__img-wrap').forEach(function(wrap) {
    wrap.style.cursor = 'pointer';
    wrap.addEventListener('click', function() {
      var img = wrap.querySelector('img');
      var lb = document.getElementById('lf-lightbox');
      var lbImg = document.getElementById('lf-lightbox-img');
      lbImg.src = img.src.replace(/width=\d+/, 'width=2000');
      lbImg.alt = img.alt;
      lb.classList.add('is-active');
    });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') document.getElementById('lf-lightbox').classList.remove('is-active');
  });
</script>

<style>
  .lf-portfolio {
    padding: 84px 0;
    background: #111111;
    color: #ffffff;
  }

  .lf-portfolio__eyebrow {
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 6px;
    color: #c41230;
    margin: 0 0 16px;
    text-align: center;
  }

  .lf-portfolio__heading {
    font-family: var(--sole-heading-font, inherit);
    font-size: clamp(3.2rem, 5vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 20px;
    line-height: 1;
    letter-spacing: -1px;
    color: #ffffff;
  }

  .lf-portfolio__text {
    text-align: center;
    color: #bbbbbb;
    font-size: 1.65rem;
    max-width: 700px;
    margin: 0 auto 48px;
    line-height: 1.5;
    font-weight: 300;
  }

  .lf-portfolio__grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 28px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .lf-portfolio__item {
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .lf-portfolio__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
  }

  .lf-portfolio__img-wrap {
    overflow: hidden;
  }

  .lf-portfolio__item {
    min-width: 0;
    overflow: hidden;
  }

  .lf-portfolio__img {
    width: 100%;
    height: 350px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .lf-portfolio__item:hover .lf-portfolio__img {
    transform: scale(1.03);
  }

  .lf-portfolio__info {
    padding: 24px 28px;
  }

  .lf-portfolio__caption {
    font-size: 1.8rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 8px;
    letter-spacing: 1px;
    color: #ffffff;
  }

  .lf-portfolio__client {
    font-size: 1.1rem;
    color: #999;
    margin: 0 0 14px;
  }

  .lf-portfolio__tag {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: #c41230;
    color: #fff;
    padding: 8px 18px;
  }

  .lf-portfolio__cta {
    text-align: center;
    margin-top: 32px;
  }

  .lf-portfolio__button {
    display: inline-block;
    background: #c41230;
    color: #ffffff;
    padding: 0 28px;
    height: 56px;
    line-height: 56px;
    font-weight: 800;
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    border: 2px solid #c41230;
    transition: all 0.25s ease;
  }

  .lf-portfolio__button:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  .lf-portfolio__lightbox {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 40px;
    cursor: pointer;
  }

  .lf-portfolio__lightbox.is-active {
    display: flex;
  }

  .lf-portfolio__lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  }

  .lf-portfolio__lightbox-close {
    position: absolute;
    top: 20px; right: 30px;
    font-size: 3rem;
    color: #fff;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    font-weight: 300;
  }

  .lf-portfolio__lightbox-close:hover {
    color: #c41230;
  }

  .lf-portfolio__img-wrap:hover .lf-portfolio__img {
    opacity: 0.9;
  }

  @media (max-width: 700px) {
    .lf-portfolio__grid { grid-template-columns: 1fr; }
    .lf-portfolio { padding: 48px 0; }
  }
</style>

{% schema %}
{
  "name": "Large Format Portfolio",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Work" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built to Stand Out" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "From food trucks to fleet vehicles, we bring brands to life at every scale." },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Start Your Project" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "caption", "label": "Project title", "default": "Vehicle Wrap" },
        { "type": "text", "id": "client", "label": "Client", "default": "Client Name" },
        { "type": "text", "id": "service_type", "label": "Service type", "default": "Car Wrap" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "Large Format Portfolio" }
  ]
}
{% endschema %}
