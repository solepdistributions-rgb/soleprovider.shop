<section class="lf-portfolio">
  <div class="page-width">
    {% if section.settings.eyebrow != blank %}
      <p class="lf-portfolio__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="lf-portfolio__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="lf-portfolio__text">{{ section.settings.text }}</p>
    {% endif %}

    <div class="lf-portfolio__grid">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <div class="lf-portfolio__item" {{ block.shopify_attributes }}>
            <div class="lf-portfolio__img-wrap">
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.caption | default: 'Project' | escape }}"
                loading="lazy"
                class="lf-portfolio__img"
              >
            </div>
            {% if block.settings.caption != blank or block.settings.client != blank %}
              <div class="lf-portfolio__info">
                {% if block.settings.caption != blank %}
                  <h3 class="lf-portfolio__caption">{{ block.settings.caption }}</h3>
                {% endif %}
                {% if block.settings.client != blank %}
                  <p class="lf-portfolio__client">{{ block.settings.client }}</p>
                {% endif %}
                {% if block.settings.service_type != blank %}
                  <span class="lf-portfolio__tag">{{ block.settings.service_type }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.cta_label != blank %}
      <div class="lf-portfolio__cta">
        <a href="{{ section.settings.cta_link | default: '/pages/request-quote' }}" class="lf-portfolio__button">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .lf-portfolio {
    padding: 48px 0;
    background: #111;
    color: #fff;
  }

  .lf-portfolio__eyebrow {
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #c41230;
    margin: 0 0 12px;
    text-align: center;
  }

  .lf-portfolio__heading {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 16px;
    line-height: 1;
    letter-spacing: -1px;
  }

  .lf-portfolio__text {
    text-align: center;
    color: #aaa;
    font-size: 1.15rem;
    max-width: 650px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .lf-portfolio__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
    gap: 20px;
  }

  .lf-portfolio__item {
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .lf-portfolio__item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
  }

  .lf-portfolio__img-wrap {
    overflow: hidden;
  }

  .lf-portfolio__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .lf-portfolio__item:hover .lf-portfolio__img {
    transform: scale(1.03);
  }

  .lf-portfolio__info {
    padding: 20px 24px;
  }

  .lf-portfolio__caption {
    font-size: 1.4rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 6px;
    letter-spacing: 0.5px;
  }

  .lf-portfolio__client {
    font-size: 0.95rem;
    color: #888;
    margin: 0 0 10px;
  }

  .lf-portfolio__tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    background: #c41230;
    color: #fff;
    padding: 5px 14px;
    border-radius: 3px;
  }

  .lf-portfolio__cta {
    text-align: center;
    margin-top: 32px;
  }

  .lf-portfolio__button {
    display: inline-block;
    background: #c41230;
    color: #fff;
    padding: 14px 40px;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .lf-portfolio__button:hover {
    background: #9a0e24;
    color: #fff;
  }

  @media (max-width: 600px) {
    .lf-portfolio__grid { grid-template-columns: 1fr; }
    .lf-portfolio { padding: 32px 0; }
  }
</style>

{% schema %}
{
  "name": "Large Format Portfolio",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Work" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recent Projects" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "See what we've built for our clients." },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Start Your Project" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "caption", "label": "Project title", "default": "Vehicle Wrap" },
        { "type": "text", "id": "client", "label": "Client", "default": "Client Name" },
        { "type": "text", "id": "service_type", "label": "Service type", "default": "Car Wrap" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "Large Format Portfolio" }
  ]
}
{% endschema %}
