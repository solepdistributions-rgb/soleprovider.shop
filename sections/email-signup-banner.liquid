<section class="drops-banner">
  <div class="page-width">
    <div class="drops-banner__card">
      {% if section.settings.banner_image != blank %}
        <div class="drops-banner__image-wrap">
          <img
            src="{{ section.settings.banner_image | image_url: width: 2200 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.banner_image.width }}"
            height="{{ section.settings.banner_image.height }}"
            class="drops-banner__image"
          >
        </div>
      {% endif %}

      <div class="drops-banner__overlay"></div>

      <div class="drops-banner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="drops-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="drops-banner__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="drops-banner__text">{{ section.settings.text }}</p>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="drops-banner__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .drops-banner {
    padding: 84px 0;
    background: #111111;
  }

  .drops-banner__card {
    position: relative;
    min-height: 480px;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 24px 54px rgba(0, 0, 0, 0.2);
  }

  .drops-banner__image-wrap,
  .drops-banner__image {
    width: 100%;
    height: 100%;
    display: block;
  }

  .drops-banner__image-wrap {
    position: absolute;
    inset: 0;
  }

  .drops-banner__image {
    object-fit: cover;
  }

  .drops-banner__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(17,17,17,0.86) 0%, rgba(17,17,17,0.58) 42%, rgba(17,17,17,0.18) 100%);
    z-index: 1;
  }

  .drops-banner__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding: 56px 48px;
    color: #ffffff;
  }

  .drops-banner__eyebrow {
    margin: 0 0 12px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .drops-banner__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3rem, 5vw, 5.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .drops-banner__text {
    margin: 0 0 24px;
    max-width: 56rem;
    font-size: 1.7rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.88);
  }

  .drops-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    background: #c41230;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid #c41230;
    transition: all 0.25s ease;
  }

  .drops-banner__button:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .drops-banner {
      padding: 64px 0;
    }

    .drops-banner__card {
      min-height: 400px;
    }

    .drops-banner__content {
      padding: 40px 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .drops-banner__card {
      min-height: 340px;
    }

    .drops-banner__content {
      padding: 28px 22px;
    }

    .drops-banner__text {
      font-size: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Drops Banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited Release"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sole Provider Drops"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Explore exclusive releases, featured pieces, and brand-driven drops from The Sole Provider."
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Drops"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Drops Banner"
    }
  ]
}
{% endschema %}