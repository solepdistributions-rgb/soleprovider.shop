<section class="ow-landing">
  <div class="page-width">
    <div class="ow-landing__hero">
      {% if section.settings.eyebrow != blank %}
        <p class="ow-landing__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="ow-landing__heading">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="ow-landing__text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}

      <div class="ow-landing__actions">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a href="{{ section.settings.primary_link }}" class="ow-landing__button ow-landing__button--primary">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a href="{{ section.settings.secondary_link }}" class="ow-landing__button ow-landing__button--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ow-landing__subtypes-wrap">
      <div class="ow-landing__section-intro">
        {% if section.settings.subtypes_eyebrow != blank %}
          <p class="ow-landing__section-eyebrow">{{ section.settings.subtypes_eyebrow }}</p>
        {% endif %}
        {% if section.settings.subtypes_heading != blank %}
          <h2 class="ow-landing__section-heading">{{ section.settings.subtypes_heading }}</h2>
        {% endif %}
        {% if section.settings.subtypes_text != blank %}
          <p class="ow-landing__section-text">{{ section.settings.subtypes_text }}</p>
        {% endif %}
      </div>

      <div class="ow-landing__grid">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link }}" class="ow-landing__card" {{ block.shopify_attributes }}>
            <div class="ow-landing__card-media">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                >
              {% else %}
                <div class="ow-landing__card-placeholder">
                  <span>{{ block.settings.icon_text }}</span>
                </div>
              {% endif %}
            </div>

            <div class="ow-landing__card-overlay">
              <div class="ow-landing__card-body">
                <h3 class="ow-landing__card-title">{{ block.settings.title }}</h3>

                {% if block.settings.subtitle != blank %}
                  <p class="ow-landing__card-subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}

                {% if block.settings.detail_1 != blank or block.settings.detail_2 != blank or block.settings.detail_3 != blank %}
                  <ul class="ow-landing__card-details">
                    {% if block.settings.detail_1 != blank %}
                      <li>{{ block.settings.detail_1 }}</li>
                    {% endif %}
                    {% if block.settings.detail_2 != blank %}
                      <li>{{ block.settings.detail_2 }}</li>
                    {% endif %}
                    {% if block.settings.detail_3 != blank %}
                      <li>{{ block.settings.detail_3 }}</li>
                    {% endif %}
                  </ul>
                {% endif %}

                <span class="ow-landing__card-link">Explore Styles →</span>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="ow-landing__help">
      {% if section.settings.help_heading != blank %}
        <h2 class="ow-landing__help-heading">{{ section.settings.help_heading }}</h2>
      {% endif %}

      {% if section.settings.help_text != blank %}
        <p class="ow-landing__help-text">{{ section.settings.help_text }}</p>
      {% endif %}

      <div class="ow-landing__help-actions">
        {% if section.settings.help_primary_label != blank and section.settings.help_primary_link != blank %}
          <a href="{{ section.settings.help_primary_link }}" class="ow-landing__button ow-landing__button--primary">
            {{ section.settings.help_primary_label }}
          </a>
        {% endif %}

        {% if section.settings.help_secondary_label != blank and section.settings.help_secondary_link != blank %}
          <a href="{{ section.settings.help_secondary_link }}" class="ow-landing__button ow-landing__button--secondary">
            {{ section.settings.help_secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .ow-landing {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .ow-landing__hero {
    max-width: 900px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .ow-landing__eyebrow,
  .ow-landing__section-eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ow-landing__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3.2rem, 5vw, 6rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .ow-landing__text {
    margin: 0 auto;
    max-width: 760px;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .ow-landing__actions,
  .ow-landing__help-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .ow-landing__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .ow-landing__button:hover {
    transform: translateY(-2px);
  }

  .ow-landing__button--primary {
    background: #111111;
    color: #ffffff;
    border: 2px solid #111111;
  }

  .ow-landing__button--primary:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  .ow-landing__button--secondary {
    background: transparent;
    color: #111111;
    border: 2px solid #111111;
  }

  .ow-landing__button--secondary:hover {
    background: #111111;
    color: #ffffff;
  }

  .ow-landing__subtypes-wrap {
    margin-bottom: 56px;
  }

  .ow-landing__section-intro {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 36px;
  }

  .ow-landing__section-heading {
    margin: 0 0 12px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.6rem, 4vw, 4.4rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .ow-landing__section-text {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.65;
    color: #4a4a4a;
  }

  .ow-landing__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .ow-landing__card {
    position: relative;
    display: block;
    min-height: 320px;
    overflow: hidden;
    text-decoration: none;
    background: #111111;
    border: 1px solid #d0d0d0;
    border-bottom: 4px solid #aaaaaa;
    box-shadow: 0 6px 0 #999999, 0 10px 24px rgba(0,0,0,0.12);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .ow-landing__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 14px 0 #888888, 0 22px 40px rgba(0,0,0,0.18);
    border-color: #c41230;
    border-bottom-color: #9a0e24;
  }

  .ow-landing__card-media {
    position: absolute;
    inset: 0;
  }

  .ow-landing__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ow-landing__card:hover .ow-landing__card-media img {
    transform: scale(1.05);
  }

  .ow-landing__card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #c41230 130%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ow-landing__card-placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 4.2rem;
    font-weight: 900;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
  }

  .ow-landing__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,17,17,0.94) 0%, rgba(17,17,17,0.55) 48%, rgba(17,17,17,0.08) 100%);
    display: flex;
    align-items: flex-end;
    transition: background 0.3s ease;
  }

  .ow-landing__card:hover .ow-landing__card-overlay {
    background: linear-gradient(to top, rgba(196,18,48,0.9) 0%, rgba(17,17,17,0.58) 48%, rgba(17,17,17,0.1) 100%);
  }

  .ow-landing__card-body {
    width: 100%;
    padding: 24px 22px 20px;
  }

  .ow-landing__card-title {
    margin: 0 0 8px;
    font-family: var(--sole-heading-font);
    font-size: 2.6rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .ow-landing__card-subtitle {
    margin: 0 0 12px;
    font-size: 1.38rem;
    line-height: 1.45;
    color: rgba(255,255,255,0.8);
  }

  .ow-landing__card-details {
    margin: 0 0 14px;
    padding: 0;
    list-style: none;
  }

  .ow-landing__card-details li {
    margin: 0 0 6px;
    font-size: 1.2rem;
    line-height: 1.4;
    color: rgba(255,255,255,0.72);
  }

  .ow-landing__card-link {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.6);
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .ow-landing__card:hover .ow-landing__card-link {
    color: #ffffff;
    transform: translateX(4px);
  }

  .ow-landing__help {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
    background: #ffffff;
    border: 1px solid #d8d8d8;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    padding: 34px 28px;
  }

  .ow-landing__help-heading {
    margin: 0 0 12px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.2rem, 3vw, 3.6rem);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .ow-landing__help-text {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1.65;
    color: #4a4a4a;
  }

  @media screen and (max-width: 989px) {
    .ow-landing {
      padding: 64px 0;
    }

    .ow-landing__grid {
      grid-template-columns: 1fr;
    }

    .ow-landing__card {
      min-height: 280px;
    }
  }

  @media screen and (max-width: 749px) {
    .ow-landing__heading {
      font-size: 3.8rem;
    }

    .ow-landing__card {
      min-height: 240px;
    }

    .ow-landing__card-title {
      font-size: 2.1rem;
    }

    .ow-landing__text,
    .ow-landing__section-text,
    .ow-landing__help-text {
      font-size: 1.4rem;
    }
  }
</style>

{% schema %}
