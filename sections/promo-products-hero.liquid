<section class="promo-hero">
  <div class="page-width">
    <div class="promo-hero__grid">
      <div class="promo-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="promo-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="promo-hero__heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="promo-hero__text">{{ section.settings.text }}</p>
        {% endif %}

        <div class="promo-hero__buttons">
          {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
            <a href="{{ section.settings.primary_link }}" class="promo-hero__button promo-hero__button--primary">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="promo-hero__button promo-hero__button--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="promo-hero__media">
        {% if section.settings.hero_image != blank %}
          <img
            src="{{ section.settings.hero_image | image_url: width: 1800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.hero_image.width }}"
            height="{{ section.settings.hero_image.height }}"
          >
        {% else %}
          <div class="promo-hero__placeholder">
            <span>Promotional Products</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .promo-hero {
    padding: 84px 0;
    background: linear-gradient(135deg, #111111 0%, #171717 55%, #c41230 165%);
    color: #ffffff;
  }

  .promo-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .promo-hero__content {
    max-width: 720px;
  }

  .promo-hero__eyebrow {
    margin: 0 0 12px;
    color: #ffffff;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.86;
  }

  .promo-hero__heading {
    margin: 0 0 18px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3.2rem, 6vw, 6rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .promo-hero__text {
    margin: 0 0 26px;
    font-size: 1.75rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.9);
    max-width: 62rem;
  }

  .promo-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .promo-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid transparent;
    transition: all 0.25s ease;
  }

  .promo-hero__button--primary {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  .promo-hero__button--primary:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .promo-hero__button--secondary {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .promo-hero__button--secondary:hover {
    background: #ffffff;
    color: #111111;
  }

  .promo-hero__media img,
  .promo-hero__placeholder {
    display: block;
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 20px 44px rgba(0, 0, 0, 0.2);
  }

  .promo-hero__media img {
    height: auto;
    object-fit: cover;
  }

  .promo-hero__placeholder {
    min-height: 420px;
    background: linear-gradient(135deg, #ffffff 0%, #f1f1f1 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .promo-hero__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 3rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    .promo-hero {
      padding: 64px 0;
    }

    .promo-hero__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Products Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Branded Solutions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Promotional Products"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Branded merchandise, giveaway items, print collateral, signage, and promotional solutions designed to support your business, event, or organization with quality, flexibility, and attention to detail."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Browse Categories"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Start a Quote"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Promo Products Hero"
    }
  ]
}
{% endschema %}