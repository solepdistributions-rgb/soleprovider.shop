{%- comment -%}
  Team store unified login.

  Single-entry login for every corporate store. Visitor enters their work
  email + the store password. SP Tools resolves which store matches and
  routes them to /pages/store-<slug> with the auth cookie already set.

  Privacy: no store list, no logos, no company hints. Same error message
  for wrong password, wrong email domain, or inactive store — the page
  must never reveal which companies have private stores here.

  Section settings let Sean tweak the headline and SP Tools host without
  touching this file.
{%- endcomment -%}

{%- liquid
  assign sp_host = section.settings.sp_tools_host | default: 'https://sp-tools-production.up.railway.app'
-%}

<section class="ts-wrap" data-host="{{ sp_host }}">
  <div class="ts-card">
    <div class="ts-logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 320 }}" alt="The Sole Provider" style="max-width:160px;max-height:80px">
      {% else %}
        <div class="ts-brand">The Sole Provider</div>
      {% endif %}
    </div>
    <h1 class="ts-h">{{ section.settings.heading | default: 'Team Store Login' }}</h1>
    <p class="ts-sub">{{ section.settings.subheading | default: 'Enter your work email and store password to continue.' }}</p>
    <form id="ts-form" autocomplete="on">
      <label class="ts-label" for="ts-email">Work email</label>
      <input id="ts-email" type="email" class="ts-input" autocomplete="email" required>

      <label class="ts-label" for="ts-pw">Store password</label>
      <div class="ts-pw-wrap">
        <input id="ts-pw" type="password" class="ts-input" autocomplete="current-password" required>
        <button type="button" id="ts-pw-toggle" class="ts-pw-toggle" aria-label="Show or hide password">Show</button>
      </div>

      <button type="submit" id="ts-submit" class="ts-btn">Sign in</button>
      <div id="ts-err" class="ts-err" hidden>Invalid credentials.</div>
    </form>
    <p class="ts-note">Lost your password? Contact your HR contact or The Sole Provider.</p>
  </div>
</section>

<script>
(function () {
  var root = document.querySelector('.ts-wrap');
  if (!root) return;
  var host = root.dataset.host;
  var form = document.getElementById('ts-form');
  var emailEl = document.getElementById('ts-email');
  var pwEl = document.getElementById('ts-pw');
  var pwToggle = document.getElementById('ts-pw-toggle');
  var submit = document.getElementById('ts-submit');
  var err = document.getElementById('ts-err');

  function setCookie(name, val, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 86400000);
    document.cookie = name + '=' + val + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
  }

  pwToggle.addEventListener('click', function () {
    var showing = pwEl.type === 'text';
    pwEl.type = showing ? 'password' : 'text';
    pwToggle.textContent = showing ? 'Show' : 'Hide';
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    err.hidden = true;
    submit.disabled = true;
    var origLabel = submit.textContent;
    submit.textContent = 'Signing in...';
    var email = (emailEl.value || '').trim().toLowerCase();
    var password = pwEl.value || '';
    fetch(host + '/api/corp/team-store/auth', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, password: password }),
    })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
      .then(function (out) {
        if (!out.ok || !out.j || !out.j.ok) {
          err.textContent = (out.j && out.j.error) || 'Invalid credentials.';
          err.hidden = false;
          pwEl.select();
          return;
        }
        // Pre-stage the per-slug auth cookies so the store page skips its
        // gate on arrival. The store page also reads cs_email_<slug> for
        // quota and reorder lookups.
        setCookie('cs_authed_' + out.j.slug, '1', 30);
        setCookie('cs_email_' + out.j.slug, email, 30);
        window.location.href = out.j.redirect_url;
      })
      .catch(function () {
        err.textContent = 'Network error. Try again in a moment.';
        err.hidden = false;
      })
      .finally(function () {
        submit.disabled = false;
        submit.textContent = origLabel;
      });
  });
})();
</script>

<style>
  .ts-wrap { min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 40px 16px; background: #f5f5f5; }
  .ts-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 40px 36px; max-width: 460px; width: 100%; text-align: center; box-shadow: 0 12px 32px rgba(17, 17, 17, 0.06); }
  .ts-logo { margin-bottom: 18px; }
  .ts-brand { font-family: var(--sole-heading-font, Arial), Arial, sans-serif; font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em; font-size: 1.6rem; color: #c41230; }
  .ts-h { font-family: var(--sole-heading-font, Arial), Arial, sans-serif; font-size: 2.6rem; font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin: 0 0 8px; color: #111; line-height: 1; }
  .ts-sub { color: #6b7280; margin: 0 0 22px; font-size: 1.3rem; }
  .ts-label { display: block; text-align: left; font-size: 1.05rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; color: #374151; margin: 10px 0 4px; }
  .ts-input { width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1.4rem; box-sizing: border-box; }
  .ts-input:focus { outline: 2px solid #c41230; outline-offset: -1px; border-color: #c41230; }
  .ts-pw-wrap { position: relative; }
  .ts-pw-wrap .ts-input { padding-right: 64px; }
  .ts-pw-toggle { position: absolute; top: 50%; right: 8px; transform: translateY(-50%); background: transparent; border: 0; color: #6b7280; font-size: 1.1rem; font-weight: 700; padding: 6px 10px; cursor: pointer; }
  .ts-pw-toggle:hover { color: #111; }
  .ts-btn { width: 100%; margin-top: 16px; padding: 14px; background: #c41230; color: #fff; border: 0; border-radius: 8px; font-weight: 800; font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; }
  .ts-btn:hover { filter: brightness(0.92); }
  .ts-btn:disabled { opacity: 0.6; cursor: wait; }
  .ts-err { color: #b91c1c; font-size: 1.2rem; margin-top: 12px; text-align: center; background: #fef2f2; border: 1px solid #fecaca; padding: 8px 10px; border-radius: 6px; }
  .ts-note { font-size: 1.05rem; color: #9ca3af; margin: 18px 0 0; }
</style>

{% schema %}
{
  "name": "Team Store Login",
  "settings": [
    { "type": "text", "id": "sp_tools_host", "label": "SP Tools host URL", "default": "https://sp-tools-production.up.railway.app", "info": "Where to send the login. Change only if SP Tools moves to a new domain." },
    { "type": "image_picker", "id": "logo", "label": "Logo (optional)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Team Store Login" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Enter your work email and store password to continue." }
  ],
  "presets": [
    { "name": "Team Store Login" }
  ]
}
{% endschema %}
