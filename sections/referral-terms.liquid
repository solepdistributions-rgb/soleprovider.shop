    margin-top: 56px;
    padding-top: 32px;
    border-top: 2px solid #f0f0f0;
    text-align: center;
  }
  .rterms-back {
    font-family: var(--sole-heading-font);
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .rterms-back:hover {
    color: var(--sole-red, #c41230);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 780px) {
    .rterms-section { padding: 64px 0 80px; }
    .rterms-card { padding: 44px 28px; }
    .rterms-summary { padding: 26px 24px; }
    .rterms-summary p { font-size: 1.02rem; }
    .rterms-section-block h2 { font-size: 1.4rem; }
    .rterms-section-block p, .rterms-section-block li { font-size: 1rem; line-height: 1.7; }
  }
  @media (max-width: 520px) {
    .rterms-wrap { padding: 0 16px; }
    .rterms-card { padding: 32px 20px; border-radius: 18px; }
  }
</style>

