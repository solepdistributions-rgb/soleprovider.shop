<section class="apparel-cats" id="apparel-categories">
  <div class="page-width">
    <div class="apparel-cats__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="apparel-cats__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="apparel-cats__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <p class="apparel-cats__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="apparel-cats__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="apparel-cats__card" {{ block.shopify_attributes }}>
          <div class="apparel-cats__media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {% else %}
              <div class="apparel-cats__placeholder">
                <span class="apparel-cats__placeholder-icon">{{ block.settings.icon_text }}</span>
              </div>
            {% endif %}
          </div>
          <div class="apparel-cats__overlay">
            <div class="apparel-cats__card-body">
              <h3 class="apparel-cats__title">{{ block.settings.title }}</h3>
              {% if block.settings.subtitle != blank %}
                <p class="apparel-cats__subtitle">{{ block.settings.subtitle }}</p>
              {% endif %}
              <span class="apparel-cats__arrow">Explore →</span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .apparel-cats {
    padding: 84px 0;
    background: #f5f5f5;
  }

  .apparel-cats__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 48px;
  }

  .apparel-cats__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .apparel-cats__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .apparel-cats__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  /* ── Grid layout: 3 across top, 3 across bottom ── */
  .apparel-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  /* ── Card ── */
  .apparel-cats__card {
    position: relative;
    display: block;
    min-height: 300px;
    overflow: hidden;
    text-decoration: none;
    background: #111111;
    /* 3D raised effect */
    border: 1px solid #d0d0d0;
    border-bottom: 4px solid #aaaaaa;
    box-shadow: 0 6px 0 #999999, 0 10px 24px rgba(0,0,0,0.12);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .apparel-cats__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 14px 0 #888888, 0 22px 40px rgba(0,0,0,0.18);
    border-color: #c41230;
    border-bottom-color: #9a0e24;
  }

  /* ── Image ── */
  .apparel-cats__media {
    position: absolute;
    inset: 0;
  }

  .apparel-cats__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .apparel-cats__card:hover .apparel-cats__media img {
    transform: scale(1.05);
  }

  /* ── Placeholder (no image) ── */
  .apparel-cats__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #c41230 130%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .apparel-cats__placeholder-icon {
    font-family: var(--sole-heading-font);
    font-size: 4rem;
    font-weight: 900;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
    letter-spacing: 0.04em;
  }

  /* ── Overlay gradient ── */
  .apparel-cats__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(17,17,17,0.92) 0%,
      rgba(17,17,17,0.45) 45%,
      rgba(17,17,17,0.05) 100%
    );
    display: flex;
    align-items: flex-end;
    transition: background 0.3s ease;
  }

  .apparel-cats__card:hover .apparel-cats__overlay {
    background: linear-gradient(
      to top,
      rgba(196,18,48,0.88) 0%,
      rgba(17,17,17,0.55) 50%,
      rgba(17,17,17,0.1) 100%
    );
  }

  /* ── Card body text ── */
  .apparel-cats__card-body {
    padding: 24px 20px 20px;
    width: 100%;
  }

  .apparel-cats__title {
    margin: 0 0 4px;
    font-family: var(--sole-heading-font);
    font-size: 2.4rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .apparel-cats__subtitle {
    margin: 0 0 10px;
    font-size: 1.35rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.4;
  }

  .apparel-cats__arrow {
    display: inline-block;
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .apparel-cats__card:hover .apparel-cats__arrow {
    color: #ffffff;
    transform: translateX(4px);
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .apparel-cats { padding: 64px 0; }
    .apparel-cats__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .apparel-cats__card { min-height: 260px; }
  }

  @media screen and (max-width: 749px) {
    .apparel-cats__grid { grid-template-columns: 1fr 1fr; gap: 14px; }
    .apparel-cats__card { min-height: 200px; }
    .apparel-cats__title { font-size: 1.9rem; }
  }
</style>

{% schema %}
{
  "name": "Apparel Categories Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop By Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse Apparel" },
    { "type": "textarea", "id": "text", "label": "Subtext", "default": "Select a category to explore styles, request a quote, or add items to your project." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category image" },
        { "type": "text", "id": "icon_text", "label": "Icon fallback (shows if no image)", "default": "TS" },
        { "type": "text", "id": "title", "label": "Title", "default": "T-Shirts" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Heavyweights, performance, basics" },
        { "type": "url", "id": "link", "label": "Collection link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Apparel Categories Grid",
      "blocks": [
        { "type": "category", "settings": { "icon_text": "TS", "title": "T-Shirts", "subtitle": "Heavyweights, performance, basics", "link": "/collections/apparel-tshirts" } },
        { "type": "category", "settings": { "icon_text": "HD", "title": "Hoodies & Sweatshirts", "subtitle": "Pullovers, zips, crewnecks", "link": "/collections/apparel-hoodies" } },
        { "type": "category", "settings": { "icon_text": "PL", "title": "Polos & Button-Downs", "subtitle": "Corporate, performance, casual", "link": "/collections/apparel-polos" } },
        { "type": "category", "settings": { "icon_text": "HT", "title": "Hats & Headwear", "subtitle": "Caps, beanies, visors", "link": "/collections/apparel-hats" } },
        { "type": "category", "settings": { "icon_text": "OW", "title": "Outerwear & Jackets", "subtitle": "Softshells, puffers, vests", "link": "/collections/apparel-outerwear" } },
        { "type": "category", "settings": { "icon_text": "YT", "title": "Youth & Kids", "subtitle": "Youth sizing for teams & schools", "link": "/collections/apparel-youth" } }
      ]
    }
  ]
}
{% endschema %}