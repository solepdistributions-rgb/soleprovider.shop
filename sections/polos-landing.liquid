        { "type": "text", "id": "detail_2", "label": "Detail 2", "default": "Lightweight and breathable" },
        { "type": "text", "id": "detail_3", "label": "Detail 3", "default": "Strong option for embroidery" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Polos Landing",
      "blocks": [
        {
          "type": "subtype",
          "settings": {
            "icon_text": "PP",
            "title": "Performance Polos",
            "subtitle": "Moisture-wicking polos for active use, teams, and warm-weather wear",
            "detail_1": "Great for athletic and event use",
            "detail_2": "Lightweight and breathable",
