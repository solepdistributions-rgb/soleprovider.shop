            "link": "/collections/cotton-polos"
          }
        },
        {
          "type": "subtype",
          "settings": {
            "icon_text": "WP",
            "title": "Work Polos",
            "subtitle": "Built for durability, uniform programs, and harder-wearing environments",
            "detail_1": "Ideal for crews and service teams",
            "detail_2": "Made for repeat wear",
            "detail_3": "Practical for branded uniforms",
            "link": "/collections/work-polos"
          }
        }
      ]
    }
  ]
}
{% endschema %}