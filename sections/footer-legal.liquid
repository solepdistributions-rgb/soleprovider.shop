{% comment %}
  Phase A — Dedicated footer row for legal & help links.
  Lives BELOW the main footer (quick links, contact, brand) and ABOVE
  the copyright line. Has its own heading so it's visually distinct
  and not lumped in with the rest of the footer content.
{% endcomment %}

{{ 'section-footer-legal.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-legal--{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer-legal--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="footer-legal footer-legal--{{ section.id }}"
  role="navigation"
  aria-labelledby="FooterLegal-{{ section.id }}-heading"
>
  <div class="footer-legal__inner page-width">
    <h2 id="FooterLegal-{{ section.id }}-heading" class="footer-legal__heading">
      {{ section.settings.heading | escape }}
    </h2>
    <ul class="footer-legal__links list-unstyled" role="list">
      {%- for block in section.blocks -%}
        <li class="footer-legal__item" {{ block.shopify_attributes }}>
          <a class="footer-legal__link" href="{{ block.settings.link }}">
            {{- block.settings.label | escape -}}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Footer legal links",
  "tag": "section",
  "class": "section section--footer-legal",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Legal & Help"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-sole-dark"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Page"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link",
        "settings": {
          "label": "Terms of Service",
          "link": "/pages/terms-of-service"
        }
      },
      {
        "type": "link",
        "settings": {
          "label": "Refund Policy",
          "link": "/pages/refund-policy"
        }
      },
      {
        "type": "link",
        "settings": {
          "label": "Shipping Policy",
          "link": "/pages/shipping-policy"
        }
      },
      {
        "type": "link",
        "settings": {
          "label": "Privacy Policy",
          "link": "/pages/privacy-policy"
        }
      },
      {
        "type": "link",
        "settings": {
          "label": "FAQ",
          "link": "/pages/faq"
        }
      }
    ]
  }
}
{% endschema %}
