<section class="gd-hero">
  <div class="page-width">
    <div class="gd-hero__grid">
      <div class="gd-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="gd-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="gd-hero__heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.text != blank %}
          <p class="gd-hero__text">{{ section.settings.text }}</p>
        {% endif %}
        <div class="gd-hero__badges">
          <div class="gd-hero__badge">
            <span class="gd-hero__badge-icon">✦</span>
            <span>100% In-House</span>
          </div>
          <div class="gd-hero__badge">
            <span class="gd-hero__badge-icon">✦</span>
            <span>Print-Ready Files</span>
          </div>
          <div class="gd-hero__badge">
            <span class="gd-hero__badge-icon">✦</span>
            <span>Fast Turnaround</span>
          </div>
        </div>
        <div class="gd-hero__buttons">
          <a href="#gd-quote" class="gd-btn gd-btn--primary">Request Design Quote</a>
          <a href="/pages/portfolio#pf-design" class="gd-btn gd-btn--outline">See Our Work</a>
        </div>
      </div>
      <div class="gd-hero__services">
        {% for block in section.blocks %}
          {% if block.type == 'service' %}
            <div class="gd-hero__service" {{ block.shopify_attributes }}>
              <span class="gd-hero__service-num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
              <div>
                <strong class="gd-hero__service-title">{{ block.settings.title }}</strong>
                {% if block.settings.text != blank %}
                  <p class="gd-hero__service-text">{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .gd-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: 0 26px; text-decoration: none; text-transform: uppercase; font-weight: 800; font-size: 1.4rem; letter-spacing: 0.06em; border: 2px solid transparent; transition: all 0.25s ease; }
  .gd-btn--primary { background: #c41230; color: #ffffff; border-color: #c41230; }
  .gd-btn--primary:hover { background: #ffffff; color: #111111; border-color: #ffffff; }
  .gd-btn--outline { background: transparent; color: #ffffff; border-color: rgba(255,255,255,0.5); }
  .gd-btn--outline:hover { background: #ffffff; color: #111111; border-color: #ffffff; }
  .gd-btn--dark { background: #111111; color: #ffffff; border-color: #111111; }
  .gd-btn--dark:hover { background: #c41230; border-color: #c41230; }

  .gd-hero {
    padding: 84px 0;
    background: linear-gradient(135deg, #111111 0%, #1a1a1a 60%, #c41230 170%);
    color: #ffffff;
  }
  .gd-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .gd-hero__eyebrow {
    margin: 0 0 12px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .gd-hero__heading {
    margin: 0 0 18px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3.6rem, 5.5vw, 6.4rem);
    line-height: 0.93;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }
  .gd-hero__text {
    margin: 0 0 28px;
    font-size: 1.7rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.82);
    max-width: 52rem;
  }
  .gd-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }
  .gd-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border: 1px solid rgba(255,255,255,0.2);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.8);
  }
  .gd-hero__badge-icon { color: #c41230; font-size: 1rem; }
  .gd-hero__buttons { display: flex; flex-wrap: wrap; gap: 14px; }

  .gd-hero__services {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .gd-hero__service {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    transition: background 0.22s ease;
  }
  .gd-hero__service:last-child { border-bottom: none; }
  .gd-hero__service:hover { background: rgba(196,18,48,0.1); }
  .gd-hero__service-num {
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    font-weight: 900;
    color: #c41230;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .gd-hero__service-title {
    display: block;
    font-family: var(--sole-heading-font);
    font-size: 1.8rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 4px;
  }
  .gd-hero__service-text {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.65);
  }

  @media screen and (max-width: 989px) {
    .gd-hero { padding: 64px 0; }
    .gd-hero__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

{% schema %}
{
  "name": "Graphic Design Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "In-House Graphic Design" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Design That's Built to Print" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Our in-house design team creates logos, brand identity, and print-ready artwork tailored to your business. Every file is built for production — no back and forth, no extra fees." }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Logo Design" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Original logos built for print, embroidery, and digital use." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Graphic Design Hero",
      "blocks": [
        { "type": "service", "settings": { "title": "Logo Design", "text": "Original logos built for print, embroidery, and digital use." } },
        { "type": "service", "settings": { "title": "Brand Identity", "text": "Full brand packages — logo, colors, typography, and usage guidelines." } },
        { "type": "service", "settings": { "title": "Print & Apparel Art", "text": "Screen print separations, embroidery digitizing, and DTF-ready files." } },
        { "type": "service", "settings": { "title": "Promotional Graphics", "text": "Flyers, signage, banners, and event materials." } },
        { "type": "service", "settings": { "title": "Artwork Cleanup", "text": "Take your existing logo and make it print-ready for any decoration method." } }
      ]
    }
  ]
}
{% endschema %}