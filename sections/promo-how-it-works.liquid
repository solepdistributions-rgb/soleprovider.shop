<section id="promo-categories" class="promo-categories">
  <div class="page-width">
    <div class="promo-categories__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="promo-categories__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="promo-categories__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="promo-categories__text">{{ section.settings.text }}</p>
      {% endif %}
    </div>

    <div class="promo-categories__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="promo-categories__card" {{ block.shopify_attributes }}>
          <div class="promo-categories__media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {% else %}
              <div class="promo-categories__placeholder">
                <span>{{ block.settings.title }}</span>
              </div>
            {% endif %}
          </div>

          <div class="promo-categories__overlay">
            <h3 class="promo-categories__title">{{ block.settings.title }}</h3>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .promo-categories {
    padding: 84px 0;
    background: #ffffff;
  }

  .promo-categories__intro {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 34px;
  }

  .promo-categories__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .promo-categories__heading {
    margin: 0 0 14px;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .promo-categories__text {
    margin: 0;
    font-size: 1.65rem;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .promo-categories__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .promo-categories__card {
    position: relative;
    display: block;
    min-height: 320px;
    overflow: hidden;
    border-radius: 18px;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    transform: translateY(0) scale(1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .promo-categories__card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.16);
  }

  .promo-categories__media,
  .promo-categories__media img,
  .promo-categories__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .promo-categories__media img {
    object-fit: cover;
  }

  .promo-categories__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #111111 0%, #c41230 100%);
    padding: 20px;
  }

  .promo-categories__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
  }

  .promo-categories__overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 22px 18px 18px;
    background: linear-gradient(to top, rgba(17,17,17,0.88) 0%, rgba(17,17,17,0.18) 70%, rgba(17,17,17,0) 100%);
  }

  .promo-categories__title {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: 2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  @media screen and (max-width: 989px) {
    .promo-categories {
      padding: 64px 0;
    }

    .promo-categories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .promo-categories__grid {
      grid-template-columns: 1fr;
    }

    .promo-categories__card {
      min-height: 280px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Categories Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Browse Categories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Promotional Categories"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Browse product categories to find the right promotional items for your business, event, or organization."
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Drinkware"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Categories Grid",
      "blocks": [
        {
          "type": "category_card",
          "settings": {
            "title": "Drinkware"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Bags"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Office"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Accessories"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Signage"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Giveaways"
          }
        }
      ]
    }
  ]
}
{% endschema %}