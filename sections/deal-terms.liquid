{%- liquid
  assign api_url = section.settings.api_url | default: 'https://sp-tools-production.up.railway.app'
-%}

<section class="deals-section">
  <div class="deals-wrap">

    <div class="deals-hero">
      <p class="deals-hero__eyebrow">Current Offers</p>
      <h1 class="deals-hero__heading">Active Deal Terms</h1>
      <p class="deals-hero__sub">Terms and conditions for all active promotions. Updated automatically as deals start and end.</p>
    </div>

    <div class="deals-list" id="dealsList">
      <div class="deals-loading">Loading active deals…</div>
    </div>

    <div class="deals-back-wrap">
      <a href="/" class="deals-back">&lsaquo; Back to Home</a>
    </div>

  </div>
</section>

<style>
  .deals-section {
    padding: 96px 0 120px;
    background: #fff;
  }
  .deals-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .deals-hero {
    text-align: center;
    margin-bottom: 56px;
  }
  .deals-hero__eyebrow {
    font-family: var(--sole-heading-font);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--sole-red, #c41230);
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .deals-hero__heading {
    font-family: var(--sole-heading-font);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--sole-black, #111);
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 18px;
  }
  .deals-hero__sub {
    font-family: var(--sole-body-font);
    font-size: 1.05rem;
    color: #555;
    margin: 0;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .deals-loading, .deals-empty {
    text-align: center;
    padding: 48px 24px;
    color: #888;
    font-family: var(--sole-body-font);
    font-size: 1rem;
  }
  .deals-empty strong {
    display: block;
    font-family: var(--sole-heading-font);
    color: #111;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .deal-card {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 20px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.05);
    padding: 40px 44px;
    margin-bottom: 32px;
    scroll-margin-top: 100px;
  }
  .deal-card--highlight {
    border: 2px solid var(--sole-red, #c41230);
    box-shadow: 0 16px 48px rgba(196,18,48,0.12);
  }
  .deal-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 20px;
    margin-bottom: 24px;
    border-bottom: 3px solid #fee2e6;
  }
  .deal-card__title-wrap {
    flex: 1 1 auto;
    min-width: 0;
  }
  .deal-card__title {
    font-family: var(--sole-heading-font);
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--sole-black, #111);
    margin: 0 0 8px;
    line-height: 1.15;
  }
  .deal-card__desc {
    font-family: var(--sole-body-font);
    font-size: 1rem;
    color: #555;
    margin: 0;
    line-height: 1.55;
  }
  .deal-card__code {
    flex: 0 0 auto;
    font-family: var(--sole-heading-font);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    background: var(--sole-red, #c41230);
    padding: 12px 22px;
    border-radius: 8px;
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 4px 12px rgba(196,18,48,0.25);
    transition: all 0.15s ease;
  }
  .deal-card__code:hover {
    background: #111;
  }

  .deal-card__terms-label {
    font-family: var(--sole-heading-font);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 14px;
  }
  .deal-card__terms-body {
    font-family: var(--sole-body-font);
    font-size: 0.98rem;
    line-height: 1.7;
    color: #444;
    white-space: pre-wrap;
    margin: 0;
  }

  .deal-card__tiers {
    margin: 20px 0 24px;
    padding: 20px 24px;
    background: #fff5f6;
    border: 2px solid #fde2e6;
    border-radius: 14px;
  }
  .deal-card__tiers-title {
    font-family: var(--sole-heading-font);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sole-red, #c41230);
    margin: 0 0 14px;
  }
  .deal-card__tiers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .deal-tier-row {
    background: #fff;
    border: 1px solid #fde2e6;
    border-radius: 10px;
    padding: 12px 14px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .deal-tier-row__qty {
    font-family: var(--sole-body-font);
    font-size: 0.78rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .deal-tier-row__val {
    font-family: var(--sole-heading-font);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--sole-red, #c41230);
    letter-spacing: 0.02em;
    line-height: 1.1;
  }
  .deal-tier-row__label {
    font-family: var(--sole-body-font);
    font-size: 0.72rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .deal-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid #f0f0f0;
  }
  .deal-card__meta-pill {
    font-family: var(--sole-body-font);
    font-size: 0.78rem;
    color: #666;
    background: #f5f5f5;
    padding: 5px 12px;
    border-radius: 6px;
  }

  .deals-back-wrap {
    margin-top: 40px;
    text-align: center;
  }
  .deals-back {
    font-family: var(--sole-heading-font);
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
  }
  .deals-back:hover { color: var(--sole-red, #c41230); }

  @media (max-width: 640px) {
    .deals-section { padding: 64px 0 80px; }
    .deal-card { padding: 28px 22px; }
    .deal-card__header { flex-direction: column; }
    .deal-card__code { align-self: flex-start; }
  }
</style>

<script>
(function() {
  var apiBase = {{ api_url | json }};
  var list = document.getElementById('dealsList');

  function esc(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
    });
  }

  var REFERRAL_CARD = ''
    + '<div class="deal-card deal-card--highlight" id="REFERRAL">'
    +   '<div class="deal-card__header">'
    +     '<div class="deal-card__title-wrap">'
    +       '<h2 class="deal-card__title">Refer a Friend, Earn Store Credit</h2>'
    +       '<p class="deal-card__desc">Always-on referral program. Existing clients earn 4%, non-clients earn 2%, and the referred customer gets 5% off their first order.</p>'
    +     '</div>'
    +     '<a class="deal-card__code" href="/pages/referral-program">REFERRAL</a>'
    +   '</div>'
    +   '<p class="deal-card__terms-label">Terms &amp; Conditions</p>'
    +   '<p class="deal-card__terms-body">Full referral program terms are documented on the dedicated <a href="/pages/referral-terms" style="color:var(--sole-red);text-decoration:underline">Referral Terms page</a>.</p>'
    +   '<div class="deal-card__meta">'
    +     '<span class="deal-card__meta-pill">Always active</span>'
    +     '<span class="deal-card__meta-pill">Store credit only</span>'
    +   '</div>'
    + '</div>';

  function parseTiers(config) {
    if (!config) return [];
    return String(config).split('\n')
      .map(function(l) { return l.trim(); })
      .filter(Boolean)
      .map(function(l) {
        var parts = l.split(':').map(function(s) { return parseFloat(s.trim()); });
        if (isNaN(parts[0]) || isNaN(parts[1])) return null;
        return { qty: parts[0], value: parts[1] };
      })
      .filter(Boolean);
  }

  function renderTierBlock(p) {
    var tiers = parseTiers(p.discount_config);
    if (!tiers.length) return '';
    var isArt = p.discount_type === 'art_discount';
    var title = isArt ? 'Discount Tiers' : 'Free Piece Tiers';
    var rows = tiers.map(function(t) {
      var val = isArt ? '$' + t.value : t.value;
      var label = isArt ? 'off artwork' : 'free pieces';
      return ''
        + '<div class="deal-tier-row">'
        +   '<span class="deal-tier-row__qty">Order ' + t.qty + '+</span>'
        +   '<span class="deal-tier-row__val">' + val + '</span>'
        +   '<span class="deal-tier-row__label">' + label + '</span>'
        + '</div>';
    }).join('');
    return ''
      + '<div class="deal-card__tiers">'
      +   '<p class="deal-card__tiers-title">' + title + '</p>'
      +   '<div class="deal-card__tiers-grid">' + rows + '</div>'
      + '</div>';
  }

  function render(promos) {
    var cards = [REFERRAL_CARD];

    if (promos && promos.length) {
      promos.forEach(function(p) {
        var meta = [];
        if (p.min_qty) meta.push('Min qty: ' + p.min_qty);
        if (p.end_date) meta.push('Ends ' + p.end_date);
        meta.push('Code: ' + p.code);

        cards.push(''
          + '<div class="deal-card" id="' + esc(p.code) + '">'
          +   '<div class="deal-card__header">'
          +     '<div class="deal-card__title-wrap">'
          +       '<h2 class="deal-card__title">' + esc(p.title || p.code) + '</h2>'
          +       (p.description ? '<p class="deal-card__desc">' + esc(p.description) + '</p>' : '')
          +     '</div>'
          +     '<a class="deal-card__code" href="/pages/request-quote?promo=' + encodeURIComponent(p.code) + '">' + esc(p.code) + '</a>'
          +   '</div>'
          +   renderTierBlock(p)
          +   '<p class="deal-card__terms-label">Terms &amp; Conditions</p>'
          +   '<p class="deal-card__terms-body">' + esc(p.terms || 'Contact us for full terms.') + '</p>'
          +   '<div class="deal-card__meta">' + meta.map(function(m) { return '<span class="deal-card__meta-pill">' + esc(m) + '</span>'; }).join('') + '</div>'
          + '</div>');
      });
    }

    list.innerHTML = cards.join('');

    // Scroll to hash target if present
    if (window.location.hash) {
      var target = document.getElementById(window.location.hash.slice(1));
      if (target) {
        setTimeout(function() { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 150);
      }
    }
  }

  fetch(apiBase + '/api/public/promos', { credentials: 'omit' })
    .then(function(r) { return r.json(); })
    .then(function(d) { render((d && d.promos) || []); })
    .catch(function() { render([]); });
})();
</script>

{% schema %}
{
  "name": "Deal Terms",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "SP Tools API URL",
      "default": "https://sp-tools-production.up.railway.app"
    }
  ],
  "presets": [
    { "name": "Deal Terms" }
  ]
}
{% endschema %}
