<section class="featured-work">
  <div class="page-width">
    <div class="featured-work__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="featured-work__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="featured-work__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="featured-work__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="featured-work__card" {{ block.shopify_attributes }}>
          <div class="featured-work__media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {% else %}
              <div class="featured-work__placeholder">
                <span>{{ block.settings.title }}</span>
              </div>
            {% endif %}
          </div>

          <div class="featured-work__overlay">
            <h3 class="featured-work__title">{{ block.settings.title }}</h3>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="featured-work__footer">
        <a href="{{ section.settings.button_link }}" class="featured-work__button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .featured-work {
    padding: 84px 0;
    background: #ffffff;
  }

  .featured-work__intro {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 34px;
  }

  .featured-work__eyebrow {
    margin: 0 0 10px;
    color: #c41230;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .featured-work__heading {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
  }

  .featured-work__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .featured-work__card {
    position: relative;
    display: block;
    min-height: 360px;
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    transform: translateY(0) scale(1);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .featured-work__card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.16);
  }

  .featured-work__media,
  .featured-work__media img,
  .featured-work__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .featured-work__media img {
    object-fit: cover;
  }

  .featured-work__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #c41230 0%, #111111 100%);
    padding: 20px;
  }

  .featured-work__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 2.4rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
    line-height: 1;
  }

  .featured-work__overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 22px 20px 20px;
    background: linear-gradient(to top, rgba(17,17,17,0.88) 0%, rgba(17,17,17,0.15) 70%, rgba(17,17,17,0) 100%);
  }

  .featured-work__title {
    margin: 0;
    font-family: var(--sole-heading-font);
    font-size: 2.2rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .featured-work__footer {
    text-align: center;
    margin-top: 30px;
  }

  .featured-work__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    background: #111111;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 2px solid #111111;
    transition: all 0.25s ease;
  }

  .featured-work__button:hover {
    background: #c41230;
    border-color: #c41230;
    color: #ffffff;
  }

  @media screen and (max-width: 1200px) {
    .featured-work__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .featured-work {
      padding: 64px 0;
    }
  }

  @media screen and (max-width: 749px) {
    .featured-work__grid {
      grid-template-columns: 1fr;
    }

    .featured-work__card {
      min-height: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Work Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Portfolio"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Work"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Portfolio"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "work_card",
      "name": "Work Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Apparel"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Work Grid",
      "blocks": [
        {
          "type": "work_card",
          "settings": {
            "title": "Apparel"
          }
        },
        {
          "type": "work_card",
          "settings": {
            "title": "Graphic Design"
          }
        },
        {
          "type": "work_card",
          "settings": {
            "title": "Promo Products"
          }
        },
        {
          "type": "work_card",
          "settings": {
            "title": "Large Format Branding"
          }
        }
      ]
    }
  ]
}
{% endschema %}