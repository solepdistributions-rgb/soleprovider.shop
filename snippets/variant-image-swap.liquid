{% comment %}
  Direct variant image swap - matches selected color to image filenames.
  Handles products where variants aren't linked to featured images in Shopify.
  Falls back to filename matching: e.g. "Fan Dark Green" → finds img containing "fandarkgreen".
{% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const productData = {{ product.variants | json }};
  const productImages = {{ product.images | json }};

  if (!productData || !productImages || productImages.length <= 1) return;

  // Build variant ID -> featured image src mapping (for variants that have one)
  const variantImageMap = {};
  productData.forEach(function(v) {
    if (v.featured_image) {
      variantImageMap[v.id] = v.featured_image.src;
    }
  });

  // Build variant ID -> color name mapping
  const variantColorMap = {};
  productData.forEach(function(v) {
    if (v.option1) {
      variantColorMap[v.id] = v.option1;
    }
  });

  const variantSelects = document.querySelector('variant-selects');
  if (!variantSelects) return;

  // Normalize color name for matching: lowercase, remove spaces/special chars
  function normalizeColor(name) {
    return name.toLowerCase().replace(/[^a-z0-9]/g, '');
  }

  // Find the media <li> whose image filename contains the normalized color
  function findMediaByColor(colorName) {
    var normalized = normalizeColor(colorName);
    var items = document.querySelectorAll('.product__media-item');
    var match = null;
    items.forEach(function(item) {
      var img = item.querySelector('img');
      if (img && img.src) {
        var filename = img.src.split('/').pop().split('?')[0].toLowerCase();
        // Match color in filename: e.g. "5000_fandarkgreen_model_front.jpg" contains "fandarkgreen"
        if (filename.indexOf(normalized) > -1) {
          match = item;
        }
      }
    });
    return match;
  }

  // Set a media item as active (show it, hide others)
  function setActiveMediaItem(targetItem) {
    if (!targetItem) return false;

    var items = document.querySelectorAll('.product__media-item');
    items.forEach(function(item) {
      item.classList.remove('is-active');
    });
    targetItem.classList.add('is-active');

    // Also update thumbnails if they exist
    var mediaId = targetItem.dataset.mediaId;
    if (mediaId) {
      var thumbs = document.querySelectorAll('[data-target]');
      thumbs.forEach(function(thumb) {
        var btn = thumb.querySelector('button');
        if (btn) btn.removeAttribute('aria-current');
        if (thumb.dataset.target === mediaId) {
          if (btn) btn.setAttribute('aria-current', 'true');
        }
      });
    }

    return true;
  }

  function handleVariantChange() {
    var url = new URL(window.location);
    var variantId = url.searchParams.get('variant');
    if (!variantId) return;

    // First try: use the variant's featured image src to swap on active item
    var imageSrc = variantImageMap[variantId];
    if (imageSrc) {
      // Variant has a linked featured image — find matching media item by src
      var items = document.querySelectorAll('.product__media-item');
      var cleanSrc = imageSrc.replace(/\?.*/, '').split('/').pop().toLowerCase();
      var found = false;
      items.forEach(function(item) {
        var img = item.querySelector('img');
        if (img && img.src.split('/').pop().split('?')[0].toLowerCase() === cleanSrc) {
          found = setActiveMediaItem(item);
        }
      });
      if (found) return;
    }

    // Second try: match by color name in filename
    var colorName = variantColorMap[variantId];
    if (colorName) {
      var mediaItem = findMediaByColor(colorName);
      if (mediaItem) {
        setActiveMediaItem(mediaItem);
        return;
      }
    }

    // Third try: if nothing matched, swap src on the current active image as last resort
    if (imageSrc) {
      var activeImg = document.querySelector('.product__media-item.is-active img');
      if (activeImg) {
        var cleanUrl = imageSrc.replace(/\?.*/, '');
        activeImg.src = cleanUrl + '?width=' + (activeImg.width || 800);
        activeImg.srcset = cleanUrl + '?width=400 400w, ' + cleanUrl + '?width=600 600w, ' + cleanUrl + '?width=800 800w, ' + cleanUrl + '?width=1000 1000w, ' + cleanUrl + '?width=1200 1200w';
      }
    }
  }

  // Listen for variant changes via URL updates
  var lastVariantId = null;
  function checkVariant() {
    var url = new URL(window.location);
    var variantId = url.searchParams.get('variant');
    if (variantId && variantId !== lastVariantId) {
      lastVariantId = variantId;
      // Small delay to let theme's updateMedia run first
      setTimeout(handleVariantChange, 200);
    }
  }

  // Listen for input changes on variant selects
  variantSelects.addEventListener('change', function() {
    setTimeout(checkVariant, 150);
  });

  // Also monitor URL changes via popstate
  window.addEventListener('popstate', function() {
    setTimeout(checkVariant, 150);
  });

  // MutationObserver for URL changes (theme uses replaceState)
  var observer = new MutationObserver(function() {
    checkVariant();
  });
  observer.observe(document.querySelector('head title') || document.head, {
    childList: true, subtree: true, characterData: true
  });

  // Also use a periodic check as ultimate fallback for replaceState
  var checkInterval = setInterval(checkVariant, 300);
  // Stop polling after 5 minutes to save resources
  setTimeout(function() { clearInterval(checkInterval); }, 300000);
});
</script>
