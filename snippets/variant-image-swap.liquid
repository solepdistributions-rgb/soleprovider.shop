{% comment %}
  Direct variant image swap - matches selected color to image filenames.
  Handles products where variants aren't linked to featured images in Shopify.
  Reads the selected color from the DOM (not Liquid variant data, which can be truncated).
  Falls back to filename matching: e.g. "Fan Dark Green" → finds img containing "fandarkgreen".
{% endcomment %}

<script>
(function() {
  // Normalize color name for matching: lowercase, remove spaces/special chars
  function normalizeColor(name) {
    return name.toLowerCase().replace(/[^a-z0-9]/g, '');
  }

  // Get the currently selected color name from the checked radio button
  function getSelectedColor() {
    var checked = document.querySelector('variant-selects input[type="radio"]:checked');
    return checked ? checked.value : null;
  }

  // Find the media <li> whose image filename contains the normalized color
  function findMediaByColor(colorName) {
    if (!colorName) return null;
    var normalized = normalizeColor(colorName);
    if (!normalized) return null;
    var items = document.querySelectorAll('.product__media-item');
    var match = null;
    items.forEach(function(item) {
      var img = item.querySelector('img');
      if (img && img.src) {
        var filename = img.src.split('/').pop().split('?')[0].toLowerCase();
        if (filename.indexOf(normalized) > -1) {
          match = item;
        }
      }
    });
    return match;
  }

  // Set a media item as active (show it, hide others)
  function setActiveMediaItem(targetItem) {
    if (!targetItem) return false;
    var items = document.querySelectorAll('.product__media-item');
    items.forEach(function(item) {
      item.classList.remove('is-active');
    });
    targetItem.classList.add('is-active');

    // Also update thumbnails if they exist
    var mediaId = targetItem.dataset.mediaId;
    if (mediaId) {
      var thumbs = document.querySelectorAll('[data-target]');
      thumbs.forEach(function(thumb) {
        var btn = thumb.querySelector('button');
        if (btn) btn.removeAttribute('aria-current');
        if (thumb.dataset.target === mediaId) {
          if (btn) btn.setAttribute('aria-current', 'true');
        }
      });
    }
    return true;
  }

  // Check if the active image matches the selected color; if not, fix it
  function fixActiveImage() {
    var colorName = getSelectedColor();
    if (!colorName) return;

    var normalizedColor = normalizeColor(colorName);
    if (!normalizedColor) return;

    // Check if the current active image already matches
    var activeItem = document.querySelector('.product__media-item.is-active');
    if (activeItem) {
      var activeImg = activeItem.querySelector('img');
      if (activeImg) {
        var activeFilename = activeImg.src.split('/').pop().split('?')[0].toLowerCase();
        if (activeFilename.indexOf(normalizedColor) > -1) return; // Already correct
      }
    }

    // Find and activate the matching media item
    var mediaItem = findMediaByColor(colorName);
    if (mediaItem) {
      setActiveMediaItem(mediaItem);
    }
  }

  // Hook into theme's pub/sub system (fires after theme's own updateMedia)
  if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
    subscribe(PUB_SUB_EVENTS.variantChange, function() {
      setTimeout(fixActiveImage, 100);
    });
  }

  // Listen directly on variant-selects change
  function attachChangeListener() {
    var variantSelects = document.querySelector('variant-selects');
    if (variantSelects) {
      variantSelects.addEventListener('change', function() {
        // Run after theme's fetch + updateMedia completes
        setTimeout(fixActiveImage, 500);
        setTimeout(fixActiveImage, 1000);
        setTimeout(fixActiveImage, 1500);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachChangeListener);
  } else {
    attachChangeListener();
  }

  // Periodic check as safety net (catches replaceState URL changes)
  var lastColor = null;
  setInterval(function() {
    var color = getSelectedColor();
    if (color && color !== lastColor) {
      lastColor = color;
      fixActiveImage();
    }
  }, 400);
})();
</script>
