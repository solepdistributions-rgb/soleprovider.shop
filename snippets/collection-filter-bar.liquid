{% comment %}
  Collection Filter Bar — snippets/collection-filter-bar.liquid
  Renders category-specific filter dropdowns above the product grid.
  Shows product counts per filter option.

  Usage:
    {% render 'collection-filter-bar', filter_set: 'bags', collection: collection %}
{% endcomment %}

{% if filter_set == blank or filter_set == 'none' %}{% break %}{% endif %}

{{ 'collection-filter-bar.css' | asset_url | stylesheet_tag }}

{% liquid
  assign current_url = collection.url
  assign current_tags_str = ''
  if request.url contains 'filter.p.tag='
    assign current_tags_str = request.url | split: 'filter.p.tag=' | last | split: '&' | first | url_decode
  endif
  assign all_tags = collection.all_tags
%}

{%- comment -%}
  Count products per tag. We count from collection.all_tags (which covers ALL products in the collection).
  For exact counts we'd need to iterate all products which Shopify caps at 50 per page.
  Instead, we show the tag exists (count > 0) via all_tags check.
{%- endcomment -%}

{%- capture chevron_svg -%}<svg class="ac-filter__chevron" width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>{%- endcapture -%}

{%- comment -%} ── Color options (shared across all categories) ── {%- endcomment -%}
{%- assign color_labels = 'Black,Navy,Brown,Gray,Blue,Red,Green,White,Orange,Yellow,Purple,Pink,Camo' | split: ',' -%}
{%- assign color_tags = 'colorgroup:black,colorgroup:navy,colorgroup:brown,colorgroup:gray,colorgroup:blue,colorgroup:red,colorgroup:green,colorgroup:white,colorgroup:orange,colorgroup:yellow,colorgroup:purple,colorgroup:pink,colorgroup:camo' | split: ',' -%}

<div class="ac-filters" id="ac-filter-bar">
  <div class="page-width">
    <div class="ac-filters__inner">
      <span class="ac-filters__label">Filter By</span>
      <div class="ac-filters__dropdowns">

        {%- comment -%}═══ DYNAMIC BRAND FILTER (for apparel, bags, headwear) ═══{%- endcomment -%}
        {% if filter_set == 'apparel' or filter_set == 'bags' or filter_set == 'headwear' %}
          {%- assign brand_list = '' -%}
          {%- for tag in all_tags -%}
            {%- if tag contains 'brand:' -%}
              {%- assign bval = tag | remove: 'brand:' -%}
              {%- if brand_list != '' -%}{%- assign brand_list = brand_list | append: ',' | append: bval -%}{%- else -%}{%- assign brand_list = bval -%}{%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if brand_list != '' -%}
            {%- assign brand_arr = brand_list | split: ',' | sort -%}
            <div class="ac-filter" data-filter="brand">
              <button class="ac-filter__trigger" aria-expanded="false">Brand {{ chevron_svg }}</button>
              <div class="ac-filter__panel" hidden>
                {%- for bname in brand_arr -%}
                  {%- assign btag = 'brand:' | append: bname -%}
                  <a href="{{ current_url }}?filter.p.tag={{ btag | url_encode }}" class="ac-filter__option{% if current_tags_str == btag %} ac-filter__option--active{% endif %}">
                    <span class="ac-filter__check">{% if current_tags_str == btag %}✓{% endif %}</span>
                    <span class="ac-filter__label">{{ bname | replace: '-', ' ' | capitalize }}</span>
                  </a>
                {%- endfor -%}
                <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
              </div>
            </div>
          {%- endif -%}
        {% endif %}

        {%- comment -%}═══ APPAREL-SPECIFIC FILTERS ═══{%- endcomment -%}
        {% if filter_set == 'apparel' %}
          {%- assign g_labels = 'Unisex,Womens,Youth' | split: ',' -%}
          {%- assign g_tags = 'fit:unisex,fit:womens,fit:youth' | split: ',' -%}
          <div class="ac-filter" data-filter="gender">
            <button class="ac-filter__trigger" aria-expanded="false">Gender {{ chevron_svg }}</button>
            <div class="ac-filter__panel" hidden>
              {%- for label in g_labels -%}{%- assign tag = g_tags[forloop.index0] -%}
                {%- if all_tags contains tag -%}
                <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                  <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                  <span class="ac-filter__label">{{ label }}</span>
                </a>
                {%- endif -%}
              {%- endfor -%}
              <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
            </div>
          </div>

          {%- assign w_labels = 'Lightweight,Midweight,Heavyweight,Performance' | split: ',' -%}
          {%- assign w_tags = 'weight:lightweight,weight:midweight,weight:heavyweight,weight:performance' | split: ',' -%}
          <div class="ac-filter" data-filter="weight">
            <button class="ac-filter__trigger" aria-expanded="false">Weight {{ chevron_svg }}</button>
            <div class="ac-filter__panel" hidden>
              {%- for label in w_labels -%}{%- assign tag = w_tags[forloop.index0] -%}
                {%- if all_tags contains tag -%}
                <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                  <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                  <span class="ac-filter__label">{{ label }}</span>
                </a>
                {%- endif -%}
              {%- endfor -%}
              <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
            </div>
          </div>

          {% if collection.handle contains 'sweatshirt' or collection.handle contains 'outerwear' or collection.handle contains 'fleece' or collection.handle contains 'hoodie' or collection.handle contains 'full-zip' or collection.handle contains 'quarter-zip' %}
            {%- assign h_labels = 'Has Hood,No Hood,Full Zip,Quarter Zip' | split: ',' -%}
            {%- assign h_tags = 'hood:yes,hood:no,hood:fullzip,hood:quarterzip' | split: ',' -%}
            <div class="ac-filter" data-filter="style">
              <button class="ac-filter__trigger" aria-expanded="false">Style {{ chevron_svg }}</button>
              <div class="ac-filter__panel" hidden>
                {%- for label in h_labels -%}{%- assign tag = h_tags[forloop.index0] -%}
                  {%- if all_tags contains tag -%}
                  <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                    <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                    <span class="ac-filter__label">{{ label }}</span>
                  </a>
                  {%- endif -%}
                {%- endfor -%}
                <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
              </div>
            </div>
          {% endif %}
        {% endif %}

        {%- comment -%}═══ TYPE FILTER (category-specific) ═══{%- endcomment -%}
        {% if filter_set == 'bags' %}
          {%- assign t_labels = 'Backpacks,Duffels,Totes,Coolers & Lunch,Cinch Packs,Drawstring,Laptop Bags,Travel,Rolling' | split: ',' -%}
          {%- assign t_tags = 'cat:backpacks,cat:duffels,cat:totes,cat:coolers-dry-bags,cat:cinch-packs,cat:drawstring,cat:laptop-bags,cat:travel,cat:rolling' | split: ',' -%}
        {% elsif filter_set == 'drinkware' %}
          {%- assign t_labels = 'Tumblers & Mugs,Water Bottles,Can Coolers,Sport Bottles,Flasks' | split: ',' -%}
          {%- assign t_tags = 'cat:mugs-tumblers,cat:water-bottles,cat:can-coolers,cat:sport-bottles,cat:water-bottles-and-flasks' | split: ',' -%}
        {% elsif filter_set == 'headwear' %}
          {%- assign t_labels = 'Structured,Unstructured,Mesh Back,Performance,Flexfit,Beanies,Bucket,Visors' | split: ',' -%}
          {%- assign t_tags = 'style:structured,style:unstructured,style:mesh-back,style:performance,style:flexfit,style:beanies,style:bucket,style:visors' | split: ',' -%}
        {% elsif filter_set == 'tech' %}
          {%- assign t_labels = 'Power Banks & Chargers,Speakers & Sound,Phone & Computer,Cables,Earbuds,USB Drives' | split: ',' -%}
          {%- assign t_tags = 'cat:power-banks-chargers,cat:sound,cat:phone-computer-accessories,cat:cables,cat:earbuds,cat:usb-flash-drives' | split: ',' -%}
        {% elsif filter_set == 'writing' %}
          {%- assign t_labels = 'Ballpoint Pens,Stylus & Multi-Function,Rollerball,Pencils & Markers,Journals,Padfolios,Notebooks,Sticky Notes' | split: ',' -%}
          {%- assign t_tags = 'cat:ballpoint-pens,cat:stylus-multi-function-pens,cat:rollerball-pens,cat:pencils-highlighters,cat:journal-books,cat:padfolios,cat:spiral-notebooks,cat:sticky-notes-notepads' | split: ',' -%}
        {% elsif filter_set == 'outdoor' %}
          {%- assign t_labels = 'BBQ,Picnic & Camping,Blankets & Chairs,Kitchen & Home,Games' | split: ',' -%}
          {%- assign t_tags = 'cat:bbq,cat:picnic-camping,cat:chairs,cat:kitchen-home,cat:games-spinners' | split: ',' -%}
        {% elsif filter_set == 'eco' %}
          {%- assign t_labels = 'Eco & Natural,Wellness,First Aid,Personal Care' | split: ',' -%}
          {%- assign t_tags = 'cat:eco-natural,cat:wellness,cat:first-aid-safety,cat:lip-balm-personal-care' | split: ',' -%}
        {% elsif filter_set == 'awards' %}
          {%- assign t_labels = 'Awards,Key Chains,Lanyards & Badges,Clocks & Frames,Business Cards,Watches,Sunglasses,Umbrellas' | split: ',' -%}
          {%- assign t_tags = 'cat:awards,cat:carabiners-key-chains,cat:badge-holders-lanyards,cat:clocks-frames,cat:business-card-cases,cat:watches,cat:sunglasses,cat:umbrellas' | split: ',' -%}
        {% endif %}

        {% if t_labels and filter_set != 'apparel' %}
          <div class="ac-filter" data-filter="type">
            <button class="ac-filter__trigger" aria-expanded="false">Type {{ chevron_svg }}</button>
            <div class="ac-filter__panel" hidden>
              {%- for label in t_labels -%}{%- assign tag = t_tags[forloop.index0] -%}
                {%- if all_tags contains tag -%}
                <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                  <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                  <span class="ac-filter__label">{{ label }}</span>
                </a>
                {%- endif -%}
              {%- endfor -%}
              <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
            </div>
          </div>
        {% endif %}

        {%- comment -%}═══ DRINKWARE MATERIAL ═══{%- endcomment -%}
        {% if filter_set == 'drinkware' %}
          {%- assign m_labels = 'Stainless Steel,Ceramic,Acrylic,Plastic,Glass' | split: ',' -%}
          {%- assign m_tags = 'mat:stainless-steel,mat:ceramic,mat:acrylic,mat:plastic,mat:glass' | split: ',' -%}
          {%- assign has_mat = false -%}
          {%- for tag in m_tags -%}{%- if all_tags contains tag -%}{%- assign has_mat = true -%}{%- break -%}{%- endif -%}{%- endfor -%}
          {%- if has_mat -%}
            <div class="ac-filter" data-filter="material">
              <button class="ac-filter__trigger" aria-expanded="false">Material {{ chevron_svg }}</button>
              <div class="ac-filter__panel" hidden>
                {%- for label in m_labels -%}{%- assign tag = m_tags[forloop.index0] -%}
                  {%- if all_tags contains tag -%}
                  <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                    <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                    <span class="ac-filter__label">{{ label }}</span>
                  </a>
                  {%- endif -%}
                {%- endfor -%}
                <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
              </div>
            </div>
          {%- endif -%}
        {% endif %}

        {%- comment -%}═══ COLOR FILTER (all categories) ═══{%- endcomment -%}
        {%- assign has_color = false -%}
        {%- for tag in color_tags -%}{%- if all_tags contains tag -%}{%- assign has_color = true -%}{%- break -%}{%- endif -%}{%- endfor -%}
        {%- if has_color -%}
          <div class="ac-filter" data-filter="color">
            <button class="ac-filter__trigger" aria-expanded="false">Color {{ chevron_svg }}</button>
            <div class="ac-filter__panel" hidden>
              {%- for label in color_labels -%}{%- assign tag = color_tags[forloop.index0] -%}
                {%- if all_tags contains tag -%}
                <a href="{{ current_url }}?filter.p.tag={{ tag | url_encode }}" class="ac-filter__option{% if current_tags_str == tag %} ac-filter__option--active{% endif %}">
                  <span class="ac-filter__check">{% if current_tags_str == tag %}✓{% endif %}</span>
                  <span class="ac-filter__label">{{ label }}</span>
                </a>
                {%- endif -%}
              {%- endfor -%}
              <a href="{{ current_url }}" class="ac-filter__clear">Clear</a>
            </div>
          </div>
        {%- endif -%}

      </div>

      <div class="ac-filters__active" id="ac-active-tags">
        {% if current_tags_str != '' %}
          <a href="{{ current_url }}" class="ac-filters__clear-all">✕ Clear all filters</a>
        {% endif %}
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var filters = document.querySelectorAll('#ac-filter-bar .ac-filter');
    filters.forEach(function(filter) {
      var trigger = filter.querySelector('.ac-filter__trigger');
      var panel = filter.querySelector('.ac-filter__panel');
      trigger.addEventListener('click', function(e) {
        var isOpen = trigger.getAttribute('aria-expanded') === 'true';
        filters.forEach(function(f) {
          f.querySelector('.ac-filter__trigger').setAttribute('aria-expanded', 'false');
          f.querySelector('.ac-filter__panel').hidden = true;
        });
        if (!isOpen) { trigger.setAttribute('aria-expanded', 'true'); panel.hidden = false; }
      });
    });
    document.addEventListener('click', function(e) {
      if (!e.target.closest('#ac-filter-bar .ac-filter')) {
        filters.forEach(function(f) {
          f.querySelector('.ac-filter__trigger').setAttribute('aria-expanded', 'false');
          f.querySelector('.ac-filter__panel').hidden = true;
        });
      }
    });
  });
</script>
