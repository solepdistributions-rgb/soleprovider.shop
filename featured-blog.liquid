<section class="drops-hero">
  <div class="page-width">
    <div class="drops-hero__grid">
      <div class="drops-hero__content">
        {% if section.settings.eyebrow != blank %}
          <p class="drops-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="drops-hero__heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="drops-hero__text rte">{{ section.settings.text }}</div>
        {% endif %}

        <div class="drops-hero__buttons">
          {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
            <a href="{{ section.settings.primary_link }}" class="drops-hero__button drops-hero__button--primary">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="drops-hero__button drops-hero__button--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="drops-hero__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% else %}
          <div class="drops-hero__placeholder">
            <span>Exclusive Drops</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .drops-hero {
    padding: 88px 0;
    background:
      radial-gradient(circle at top right, rgba(196,18,48,0.18), transparent 28%),
      linear-gradient(135deg, #0f0f10 0%, #171717 55%, #1f1f1f 100%);
    color: #ffffff;
  }

  .drops-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 40px;
    align-items: center;
  }

  .drops-hero__content {
    max-width: 720px;
  }

  .drops-hero__eyebrow {
    margin: 0 0 12px;
    color: #c41230;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .drops-hero__heading {
    margin: 0 0 16px;
    font-family: var(--sole-heading-font);
    font-size: clamp(3.4rem, 6vw, 6.4rem);
    line-height: 0.93;
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
  }

  .drops-hero__text {
    margin: 0 0 26px;
    font-size: 1.65rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.82);
  }

  .drops-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .drops-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    border: 2px solid transparent;
    transition: all 0.22s ease;
  }

  .drops-hero__button--primary {
    background: #c41230;
    color: #ffffff;
    border-color: #c41230;
  }

  .drops-hero__button--primary:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .drops-hero__button--secondary {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255,255,255,0.4);
  }

  .drops-hero__button--secondary:hover {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .drops-hero__media img,
  .drops-hero__placeholder {
    display: block;
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 20px 44px rgba(0, 0, 0, 0.25);
  }

  .drops-hero__media img {
    height: auto;
    object-fit: cover;
  }

  .drops-hero__placeholder {
    min-height: 460px;
    background: linear-gradient(135deg, #ffffff 0%, #f1f1f1 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .drops-hero__placeholder span {
    font-family: var(--sole-heading-font);
    font-size: 3rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    .drops-hero {
      padding: 68px 0;
    }

    .drops-hero__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .drops-hero__heading {
      font-size: clamp(3rem, 11vw, 4.9rem);
    }

    .drops-hero__text {
      font-size: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Exclusive Drops Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited Release"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Exclusive Drops"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>A monthly featured product from The Sole Provider. Limited runs, featured pieces, and brand-driven releases available to shop directly.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Current Drop"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View Portfolio"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Exclusive Drops Hero"
    }
  ]
}
{% endschema %}